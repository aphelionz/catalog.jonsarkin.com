<div class="page-width">
  <header class="section-header text-center">
    <nav>      
      {% for link in linklists["about-menu"].links %}
      	<a {% if link.active %}disabled{% endif %} class="btn btn--secondary" href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>
  </header>
  
  <div class="grid">
    <div class="grid__item medium-up--four-fifths medium-up--push-one-tenth">
      <h1 class="section-header__title h2">{{ page.title }}</h1>
      
      <br />
      
      <div class="rte">
        {{ page.content }}
      </div>
    </div>
  </div>
</div>
