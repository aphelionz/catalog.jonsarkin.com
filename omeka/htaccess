SetEnv APPLICATION_ENV "production"

RewriteEngine On

# --- Clean URLs: strip /s/catalog/ prefix ---

# 301 redirect old /s/catalog URLs to clean URLs
# /s/catalog → /
RewriteCond %{THE_REQUEST} \s/s/catalog[\s?]
RewriteRule ^s/catalog$ / [R=301,L]
# /s/catalog/path → /path (query string preserved automatically)
RewriteRule ^s/catalog/(.+)$ /$1 [R=301,L]

# --- Omeka S front controller (from upstream .htaccess) ---

# The following rule tells Apache that if the requested filename
# exists, simply serve it.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule !\.(php[0-9]?|phtml|phps|phar|hphp)$ - [NC,C]
RewriteRule !(?:^|/)\.(?!well-known(?:/.*)?$) - [C]
RewriteRule .* - [L]

# Strip any trailing slashes from incoming requests
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^(.+)/+$
RewriteRule .* %1 [R=307,L]

# Rewrite all other queries to index.php (front controller).
RewriteCond %{ENV:REDIRECT_OMEKA_REQ} !"1"
RewriteRule ^(.*)$ /index.php [E=OMEKA_REQ:"1",L]

# Block access to all .ini files.
<FilesMatch "\.ini$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
