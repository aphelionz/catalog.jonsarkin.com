<?php
/**
 * Sarkin-Jeppesen — FacetedBrowse page override
 *
 * Renders facets and browse results entirely server-side (no AJAX).
 * Facet counts are computed in PageController::pageAction() using
 * optimized GROUP BY queries. Clicking a facet navigates with URL
 * params, triggering a full page reload with updated counts.
 */

// Core FacetedBrowse object (for updateSelectList)
$this->headScript()->appendFile($this->assetUrl('js/faceted-browse.js', 'FacetedBrowse'));

$this->htmlElement('body')->appendAttribute('class', 'faceted-browse-page resource browse');
$this->pageTitle($page->title(), 2);

$escape    = $this->plugin('escapeHtml');
$translate = $this->plugin('translate');

// Set placeholders for facet render templates
$this->placeholder('facetCounts')->set($facetCounts);
$this->placeholder('activeFilters')->set($activeFilters);

// ── Browse result helpers (same as browse.phtml) ──
$headingTerm = $this->siteSetting('browse_heading_property_term');
$bodyTerm    = $this->siteSetting('browse_body_property_term');

$val = function ($item, $term, $fallback = "\xE2\x80\x94") use ($escape) {
    $v = $item->value($term, ['default' => null]);
    return $v ? $escape((string) $v) : $fallback;
};
$isArtworkDate = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '' || $str === "\xE2\x80\x94") return false;
    if (preg_match('/^\d{4}:\d{2}:\d{2}/', $str)) return false;
    if (preg_match('/\d{4}-\d{2}-\d{2}T/', $str)) return false;
    return true;
};
$isNotMime = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '' || $str === "\xE2\x80\x94") return false;
    if (preg_match('#^[\w-]+/[\w.+-]+$#', $str)) return false;
    return true;
};
?>
<?php
// Derive heading from active TYPE filter (resource_class_id[])
$typeLabels = [225 => 'Artwork', 118 => 'Writing', 286 => 'Video'];
$activeClassIds = (array)($this->params()->fromQuery('resource_class_id', []));
$activeClassId = count($activeClassIds) === 1 ? (int)reset($activeClassIds) : null;
$typeLabel = $activeClassId && isset($typeLabels[$activeClassId])
    ? $typeLabels[$activeClassId]
    : $escape($page->title());

// Build export query early so we can place links in the heading
$apiExportUrl = '';
if ($category) {
    $exportQuery = [];
    parse_str($category->query() ?? '', $exportQuery);
    foreach (['resource_class_id', 'item_set_id', 'resource_template_id', 'property', 'fulltext_search'] as $key) {
        if (isset($_GET[$key])) {
            $exportQuery[$key] = $_GET[$key];
        }
    }
    $apiExportUrl = $this->url('api/default', ['resource' => 'items'], ['query' => $exportQuery + ['per_page' => 5000]]);
}
?>
<div class="browse-type-heading">
    <h2><?php echo $typeLabel; ?></h2>
    <?php if ($apiExportUrl): ?>
    <div class="export-bar">
        <a href="#" class="pill-button export-csv-btn">[export csv]</a>
        <a href="<?php echo $escape($apiExportUrl); ?>" class="pill-button" target="_blank">[export json]</a>
    </div>
    <?php endif; ?>
</div>
<?php
// ── Build active-filter pills (everything except resource_class_id) ──
$filterPills = [];
$currentParams = $_GET;

// Item sets
foreach ($activeFilters['item_set_id'] as $setId) {
    $setId = (int) $setId;
    try {
        $itemSet = $this->api()->read('item_sets', $setId)->getContent();
        $label = $itemSet->displayTitle();
    } catch (\Exception $e) {
        $label = 'Set #' . $setId;
    }
    // Build URL without this item_set_id
    $remaining = array_filter((array)($currentParams['item_set_id'] ?? []), function($v) use ($setId) { return (int)$v !== $setId; });
    $removeParams = $currentParams;
    if ($remaining) {
        $removeParams['item_set_id'] = array_values($remaining);
    } else {
        unset($removeParams['item_set_id']);
    }
    $filterPills[] = ['label' => $label, 'url' => '?' . http_build_query($removeParams)];
}

// Resource templates
foreach ($activeFilters['resource_template_id'] as $tplId) {
    $tplId = (int) $tplId;
    try {
        $tpl = $this->api()->read('resource_templates', $tplId)->getContent();
        $label = $tpl->label();
    } catch (\Exception $e) {
        $label = 'Template #' . $tplId;
    }
    $remaining = array_filter((array)($currentParams['resource_template_id'] ?? []), function($v) use ($tplId) { return (int)$v !== $tplId; });
    $removeParams = $currentParams;
    if ($remaining) {
        $removeParams['resource_template_id'] = array_values($remaining);
    } else {
        unset($removeParams['resource_template_id']);
    }
    $filterPills[] = ['label' => $label, 'url' => '?' . http_build_query($removeParams)];
}

// Property facets (value filters — work type, medium, support, motifs, etc.)
foreach ($activeFilters['property'] as $idx => $prop) {
    $text = $prop['text'] ?? '';
    if ($text === '') continue;
    $filterPills[] = [
        'label' => $text,
        'url' => '?' . http_build_query(array_merge($currentParams, [
            'property' => array_values(array_filter($activeFilters['property'], function($k) use ($idx) { return $k !== $idx; }, ARRAY_FILTER_USE_KEY))
        ]))
    ];
}

// Full-text search
if (!empty($activeFilters['fulltext_search'])) {
    $removeParams = $currentParams;
    unset($removeParams['fulltext_search']);
    $filterPills[] = ['label' => '"' . $activeFilters['fulltext_search'] . '"', 'url' => '?' . http_build_query($removeParams)];
}
?>
<?php if ($filterPills): ?>
<div class="active-filters">
    <?php foreach ($filterPills as $pill):
        $hue = crc32($pill['label']) % 360;
        if ($hue < 0) $hue += 360;
    ?>
    <a href="<?php echo $escape($pill['url']); ?>" class="filter-pill" style="--pill-hue:<?php echo $hue; ?>"><span class="filter-pill-x">&times;</span><?php echo $escape($pill['label']); ?></a>
    <?php endforeach; ?>
</div>
<?php endif; ?>
<div id="container" data-category-id="<?php echo $escape($categoryId); ?>">
    <button id="section-sidebar-modal-toggle" type="button"><?php echo $translate('Filters'); ?></button>

    <?php // ── SIDEBAR: Facets ── ?>
    <div class="sidebar-column">
    <div id="section-sidebar" class="mobile modal-panel" aria-describedby="facet-modal-description" aria-label="<?php echo $translate('Filters'); ?>">
    <?php if ($category): ?>
        <button id="section-sidebar-modal-close" class="close-button" aria-label="<?php echo $escape($translate('Close')); ?>" type="button">
            <span aria-hidden="true" class="close-glyph"></span>
        </button>
        <div class="sr-only" id="facet-modal-description">
            This is a dialog window which overlays the main content of the page. Pressing the Close Modal button at the top right of the modal will close the modal and bring you back to where you were on the page.
        </div>
        <fieldset class="facets-container">
            <legend><?php echo $category->name(); ?></legend>
            <?php
            $categoryOptions = [
                'value_facet_mode' => $category->valueFacetMode(),
            ];
            ?>
            <div id="facets"
                data-category-id="<?php echo $escape($category->id()); ?>"
                data-category-options="<?php echo $escape(json_encode($categoryOptions)); ?>">
                <?php foreach ($category->facets() as $facet): ?>
                <?php if ($this->facetedBrowse()->facetIsKnown($facet)): ?>
                <?php
                $selectType = $facet->data('select_type') ?? '';
                $isTextFacet = in_array($selectType, ['text_input']);
                $myFacetCounts = $facetCounts[$facet->id()] ?? [];
                $hasVisibleValues = $isTextFacet || !empty(array_filter($myFacetCounts));
                ?>
                <?php if ($hasVisibleValues): ?>
                <fieldset class="facet"
                    data-facet-id="<?php echo $escape($facet->id()); ?>"
                    data-facet-type="<?php echo $escape($facet->type()); ?>"
                    data-facet-data="<?php echo $escape(json_encode($facet->data())); ?>">
                    <legend><?php echo $facet->name(); ?></legend>
                    <?php echo $this->facetedBrowse()->renderFacet($facet); ?>
                </fieldset>
                <?php endif; ?>
                <?php endif; ?>
                <?php endforeach; ?>
            </div>
        </fieldset>
    <?php elseif (count($categories) > 1): ?>
        <?php // Multi-category: show category list ?>
        <ul class="categories">
            <?php foreach ($categories as $cat): ?>
            <li>
                <a class="category" href="?faceted_browse_category_id=<?php echo $escape($cat->id()); ?>">
                    <?php echo $escape($cat->name()); ?>
                </a>
            </li>
            <?php endforeach; ?>
        </ul>
    <?php endif; ?>
    </div>
    </div>

    <?php // ── CONTENT: Browse results ── ?>
    <div id="section-content">
    <?php if ($category): ?>
        <div class="browse-controls">
            <?php echo $this->pagination(); ?>
            <?php echo $this->sortSelector($sortings); ?>
        </div>

        <?php if ($items): ?>
        <ul class="chart-grid">
            <?php foreach ($items as $item):
                $heading = $headingTerm
                    ? $item->value($headingTerm, ['default' => $translate('[Untitled]')])
                    : $item->displayTitle();
                $dateRaw = $val($item, 'dcterms:date', '') ?: $val($item, 'schema:dateCreated', '');
                $date    = $isArtworkDate($dateRaw) ? $dateRaw : '';
                $catId   = $val($item, 'dcterms:identifier', '');
                $isWriting = ($item->resourceTemplate() && $item->resourceTemplate()->id() === 3);
            ?>
            <?php if ($isWriting): ?>
            <?php
                $genre   = $val($item, 'schema:genre', '');
                $rawText = strip_tags((string) $item->value('bibo:content', ['default' => '']));
                $excerpt = (mb_strlen($rawText) > 200)
                    ? preg_replace('/\s+\S*$/', "\xE2\x80\xA6", mb_substr($rawText, 0, 200))
                    : $rawText;
                $dateYear = $date ? substr(strip_tags($date), 0, 4) : '';
                $headerParts = array_filter([$genre, $dateYear]);
            ?>
            <li class="chart-card chart-card--writing">
                <a href="<?php echo $escape($item->url()); ?>">
                    <div class="card-writing-header">
                        <?php echo $escape(implode(' · ', $headerParts)) ?: "\xE2\x80\x94"; ?>
                    </div>
                    <div class="card-excerpt"><?php echo $escape($excerpt); ?></div>
                    <div class="card-info">
                        <?php if ($catId): ?>
                            <div class="card-id"><?php echo $catId; ?></div>
                        <?php endif; ?>
                        <div class="card-title"><?php echo $escape($heading); ?></div>
                    </div>
                </a>
            </li>
            <?php else: ?>
            <?php
                $mediumRaw = $val($item, 'dcterms:medium', '');
                $medium  = $isNotMime($mediumRaw) ? $mediumRaw : '';
                $surface = $val($item, 'schema:artworkSurface', '');
                $mediumDisplay = $medium . ($surface ? ' on ' . strtolower($surface) : '');
                $height  = $val($item, 'schema:height', '');
                $width   = $val($item, 'schema:width', '');
                $extent  = $val($item, 'dcterms:extent', '');
                if ($height && $width) {
                    $dims = $height . ' × ' . $width;
                } elseif ($extent) {
                    $dims = $extent;
                } else {
                    $dims = '';
                }
                $primaryMedia = $item->primaryMedia();
                $thumbUrl = $primaryMedia ? $primaryMedia->thumbnailUrl('large') : null;
            ?>
            <li class="chart-card">
                <a href="<?php echo $escape($item->url()); ?>">
                    <div class="card-image">
                        <?php if ($thumbUrl): ?>
                            <img src="<?php echo $escape($thumbUrl); ?>"
                                 alt="<?php echo $escape($heading); ?>"
                                 loading="lazy" />
                        <?php else: ?>
                            <div class="card-image-placeholder"><?php echo $translate('No image'); ?></div>
                        <?php endif; ?>
                    </div>
                    <div class="card-facts">
                        <div class="card-fact">
                            <div class="card-fact-label"><?php echo $translate('Year'); ?></div>
                            <div class="card-fact-value"><?php echo $date; ?></div>
                        </div>
                        <div class="card-fact">
                            <div class="card-fact-label"><?php echo $translate('Size'); ?></div>
                            <div class="card-fact-value"><?php echo $dims ?: "\xE2\x80\x94"; ?></div>
                        </div>
                    </div>
                    <div class="card-info">
                        <div class="card-title"><?php echo $catId ?: $escape($heading); ?></div>
                    </div>
                </a>
            </li>
            <?php endif; ?>
            <?php endforeach; ?>
        </ul>
        <?php else: ?>
        <p><?php echo $translate('There are no results.'); ?></p>
        <?php endif; ?>

        <div class="browse-controls">
            <?php echo $this->pagination(); ?>
        </div>
    <?php endif; ?>
    </div>
</div>

<script>
$(document).ready(function() {

const container = $('#container');
const sectionSidebar = $('#section-sidebar');
const sectionContent = $('#section-content');
const categoryId = container.data('categoryId');

// ── Build URL from all current facet selections and navigate ──
function navigateWithSelections(extraParams) {
    const params = new URLSearchParams();

    // Resource class
    sectionSidebar.find('input.resource-class.selected').each(function() {
        params.append('resource_class_id[]', $(this).data('classId'));
    });
    sectionSidebar.find('select.resource-class').each(function() {
        const val = $(this).val();
        if (val) params.append('resource_class_id[]', val);
    });

    // Item set
    sectionSidebar.find('input.item-set.selected').each(function() {
        params.append('item_set_id[]', $(this).data('itemSetId'));
    });
    sectionSidebar.find('select.item-set').each(function() {
        const val = $(this).val();
        if (val) params.append('item_set_id[]', val);
    });

    // Value facets (property params)
    let propIndex = 0;
    const joiner = ($('#facets').data('categoryOptions') || {}).value_facet_mode === 'or' ? 'or' : 'and';
    sectionSidebar.find('.facet[data-facet-type="value"]').each(function() {
        const facet = $(this);
        const fd = facet.data('facetData');

        if (fd.select_type === 'text_input') {
            const input = facet.find('input.value');
            const text = input.val();
            if (text) {
                params.append('property[' + propIndex + '][joiner]', joiner);
                params.append('property[' + propIndex + '][property]', input.data('propertyId'));
                params.append('property[' + propIndex + '][type]', fd.query_type);
                params.append('property[' + propIndex + '][text]', text);
                propIndex++;
            }
            return;
        }

        if (fd.select_type === 'single_select') {
            const opt = facet.find('select.value option:selected');
            const text = opt.data('value');
            if (text) {
                params.append('property[' + propIndex + '][joiner]', joiner);
                params.append('property[' + propIndex + '][property]', opt.data('propertyId'));
                params.append('property[' + propIndex + '][type]', fd.query_type);
                params.append('property[' + propIndex + '][text]', text);
                propIndex++;
            }
            return;
        }

        // Checkboxes / radios
        facet.find('input.value.selected').each(function() {
            const prop = $(this).data('propertyId');
            const text = $(this).data('value');
            params.append('property[' + propIndex + '][joiner]', joiner);
            params.append('property[' + propIndex + '][property]', prop);
            params.append('property[' + propIndex + '][type]', fd.query_type);
            if (!['ex', 'nex'].includes(fd.query_type)) {
                params.append('property[' + propIndex + '][text]', text);
            }
            propIndex++;
        });
    });

    // Resource template
    sectionSidebar.find('input.resource-template.selected').each(function() {
        params.append('resource_template_id[]', $(this).data('templateId'));
    });

    // Full-text search
    sectionSidebar.find('input.full-text').each(function() {
        const text = $(this).val();
        if (text) params.set('fulltext_search', text);
    });

    // Preserve URL-based array filters not set via sidebar (e.g. item_set_id from external link)
    const currentParams = new URLSearchParams(window.location.search);
    ['item_set_id', 'resource_class_id', 'resource_template_id'].forEach(function(key) {
        if (!params.has(key + '[]')) {
            currentParams.forEach(function(v, k) {
                if (k === key + '[]') {
                    params.append(key + '[]', v);
                } else if (new RegExp('^' + key.replace(/([[\]])/g, '\\$1') + '\\[\\d+\\]$').test(k)) {
                    params.append(key + '[]', v);
                }
            });
        }
    });

    // Extra params (sort, page override)
    if (extraParams) {
        for (const [k, v] of Object.entries(extraParams)) {
            params.set(k, v);
        }
    }

    // Preserve sort from current URL unless overridden
    if (!params.has('sort_by') && currentParams.get('sort_by')) {
        params.set('sort_by', currentParams.get('sort_by'));
    }
    if (!params.has('sort_order') && currentParams.get('sort_order')) {
        params.set('sort_order', currentParams.get('sort_order'));
    }

    params.set('faceted_browse_category_id', categoryId);
    window.location.href = window.location.pathname + '?' + params.toString();
}

// ── Update truncated select lists on load ──
sectionSidebar.find('.select-list').each(function() {
    FacetedBrowse.updateSelectList($(this));
});

// ── Facet interaction: checkbox / radio ──
function handleFacetClick(e, inputSelector) {
    const thisInput = $(e.target).closest(inputSelector);
    if (!thisInput.length) return;
    const facet = thisInput.closest('.facet');
    const fd = facet.data('facetData');

    if (fd.select_type === 'single_list') {
        facet.find(inputSelector).not(thisInput).removeClass('selected');
        thisInput.prop('checked', !thisInput.hasClass('selected'));
    }
    thisInput.toggleClass('selected');
    navigateWithSelections();
}

container.on('click', 'input.resource-class', function(e) { handleFacetClick(e, 'input.resource-class'); });
container.on('click', 'input.item-set', function(e) { handleFacetClick(e, 'input.item-set'); });
container.on('click', 'input.resource-template', function(e) { handleFacetClick(e, 'input.resource-template'); });
container.on('click', 'input.value[type="checkbox"], input.value[type="radio"]', function(e) { handleFacetClick(e, 'input.value'); });

// Dropdowns
container.on('change', 'select.resource-class, select.item-set, select.value', function() {
    navigateWithSelections();
});

// Text input (debounced)
let textTimer;
container.on('keyup', 'input.value[type="text"], input.full-text', function() {
    clearTimeout(textTimer);
    textTimer = setTimeout(navigateWithSelections, 500);
});

// ── Category click (multi-category pages) ──
container.on('click', '.category', function(e) {
    e.preventDefault();
    const catId = $(this).data('categoryId');
    window.location.href = window.location.pathname + '?faceted_browse_category_id=' + catId;
});

// ── Pagination ──
container.on('click', '.next, .previous', function(e) {
    e.preventDefault();
    if ($(this).hasClass('inactive')) return;
    try {
        const href = new URL($(this).prop('href'), window.location.origin);
        const pageNum = href.searchParams.get('page');
        if (pageNum) {
            navigateWithSelections({page: pageNum});
        }
    } catch(err) {
        window.location.href = $(this).prop('href');
    }
});

container.on('submit', '.pagination form', function(e) {
    e.preventDefault();
    const pageNum = $(this).find('input[name="page"]').val();
    if (pageNum) {
        navigateWithSelections({page: pageNum});
    }
});

// ── Sort ──
container.on('submit', 'form.sorting', function(e) {
    e.preventDefault();
    const sortBy = $(this).find('select[name="sort_by"]').val();
    const sortOrder = $(this).find('select[name="sort_order"]').val();
    const extras = {};
    if (sortBy) extras.sort_by = sortBy;
    if (sortOrder) extras.sort_order = sortOrder;
    navigateWithSelections(extras);
});

// ── Permalink ──
container.on('click', '.permalink', function(e) {
    e.preventDefault();
    const permalink = window.location.href;
    if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(permalink).then(showCopySuccess);
    } else {
        const tmp = $('<input>');
        $('body').append(tmp);
        tmp.val(permalink).select();
        document.execCommand('copy');
        tmp.remove();
        showCopySuccess();
    }
});

function showCopySuccess() {
    $('.permalink .success').addClass('active').show();
    $('.permalink .default').addClass('inactive');
    setTimeout(function() {
        $('.permalink .success').fadeOut(1000, function() {
            $(this).removeClass('active');
            $('.permalink .default').removeClass('inactive');
        });
    }, 1500);
}

// ── Expand / collapse list ──
container.on('click', '.select-list-expand', function(e) {
    e.preventDefault();
    const selectList = $(this).closest('.facet').find('.select-list');
    selectList.addClass('expanded');
    FacetedBrowse.updateSelectList(selectList);
});

container.on('click', '.select-list-collapse', function(e) {
    e.preventDefault();
    const selectList = $(this).closest('.facet').find('.select-list');
    selectList.removeClass('expanded');
    FacetedBrowse.updateSelectList(selectList);
});

// ── Mobile modal ──
const modalToggleButton = $('#section-sidebar-modal-toggle');
const mediaQuery = window.matchMedia('(min-width: 896px)');

function handleTabletChange(e) {
    modalToggleButton.attr('aria-expanded', 'false');
    sectionContent.attr('aria-hidden', 'true').removeClass('open');
    if (e.matches) {
        sectionSidebar.attr('aria-hidden', 'false');
    }
}

container.on('click', '#section-sidebar-modal-toggle', function() {
    sectionSidebar.toggleClass('open');
    if (modalToggleButton.attr('aria-expanded') == 'true') {
        modalToggleButton.attr('aria-expanded', 'false');
        sectionSidebar.attr('aria-hidden', 'true');
    } else {
        modalToggleButton.attr('aria-expanded', 'true');
        sectionSidebar.attr('aria-hidden', 'false');
    }
});

sectionSidebar.on('click', '.close-button', function() {
    modalToggleButton.trigger('click').trigger('focus');
});

mediaQuery.addListener(handleTabletChange);
handleTabletChange(mediaQuery);

// ── CSV Export ──
$('.export-csv-btn').on('click', function(e) {
    e.preventDefault();
    var btn = $(this);
    var origText = btn.text();
    btn.text('Exporting\u2026').css('pointer-events', 'none');

    var apiUrl = <?php echo json_encode($apiExportUrl); ?>;

    function fetchAll(url, page, acc) {
        var sep = url.indexOf('?') === -1 ? '?' : '&';
        return $.getJSON(url + sep + 'page=' + page + '&per_page=500').then(function(data, status, xhr) {
            acc = acc.concat(data);
            var total = parseInt(xhr.getResponseHeader('Omeka-S-Total-Results') || '0', 10);
            if (acc.length < total) {
                return fetchAll(url, page + 1, acc);
            }
            return acc;
        });
    }

    fetchAll(apiUrl, 1, []).then(function(items) {
        var termSet = {};
        items.forEach(function(item) {
            Object.keys(item).forEach(function(k) {
                if (k.indexOf(':') > 0 && k.indexOf('o:') !== 0 && k.indexOf('@') !== 0) {
                    termSet[k] = true;
                }
            });
        });
        var terms = Object.keys(termSet).sort();
        var cols = ['o:id', 'o:title'].concat(terms);
        var header = cols.map(function(c) { return '"' + c.replace(/"/g, '""') + '"'; }).join(',');

        var rows = items.map(function(item) {
            return cols.map(function(col) {
                if (col === 'o:id') return item['o:id'] || '';
                if (col === 'o:title') return '"' + (item['o:title'] || '').replace(/"/g, '""') + '"';
                var vals = item[col];
                if (!vals || !vals.length) return '""';
                var text = vals.map(function(v) {
                    return v['@value'] || v['o:label'] || '';
                }).join('; ');
                return '"' + text.replace(/"/g, '""') + '"';
            }).join(',');
        });

        var csv = header + '\n' + rows.join('\n');
        var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        var link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'export.csv';
        link.click();
        URL.revokeObjectURL(link.href);
    }).always(function() {
        btn.text(origText).css('pointer-events', '');
    });
});

});
</script>
