<?php
/**
 * Sarkin-Jeppesen — ResourceClass facet render override
 *
 * Hides resource classes with 0 matching items, displays counts,
 * and marks selected classes server-side from URL params.
 */
$counts = $this->placeholder('facetCounts')->getValue() ?: [];
$myCounts = $counts[$facet->id()] ?? [];

$activeFilters = $this->placeholder('activeFilters')->getValue() ?: [];
$activeClassIds = array_map('strval', $activeFilters['resource_class_id'] ?? []);

$classLabels = [225 => 'Artwork', 118 => 'Writing'];
?>
<?php if ($singleSelect): ?>
<?php
$allOptions = [];
foreach ($classes as $class) {
    $count = $myCounts[$class->id()] ?? 0;
    $label = $classLabels[$class->id()] ?? $class->label();
    $allOptions[] = [
        'value' => $class->id(),
        'label' => $count > 0 ? sprintf('%s (%d)', $label, $count) : $label,
        'attributes' => [],
    ];
}
if ($allOptions) {
    $singleSelect->setValueOptions($allOptions);
    if ($activeClassIds) {
        $singleSelect->setValue($activeClassIds[0]);
    }
    echo $this->formElement($singleSelect);
}
?>
<?php else: ?>
<ul class="select-list" data-truncate-list-items="<?php echo $this->escapeHtml($facet->data('truncate_resource_classes')); ?>">
    <?php $index = 0; ?>
    <?php foreach ($classes as $class): ?>
    <?php
    $count = $myCounts[$class->id()] ?? 0;
    if ($count === 0) continue;
    $selected = in_array((string)$class->id(), $activeClassIds);
    ?>
    <li class="select-list-item" data-index="<?php echo $this->escapeHtml($index++); ?>">
        <label>
            <input
                class="resource-class<?php echo $selected ? ' selected' : ''; ?>"
                type="<?php echo ('multiple_list' === $facet->data('select_type')) ? 'checkbox' : 'radio'; ?>"
                name="<?php echo sprintf('resource_class_%s', $facet->id()); ?>"
                data-class-id="<?php echo $this->escapeHtml($class->id()); ?>"
                <?php echo $selected ? 'checked' : ''; ?>>
                <?php echo $classLabels[$class->id()] ?? $class->label(); ?>
                <span class="facet-count">(<?php echo $count; ?>)</span>
        </label>
    </li>
    <?php endforeach; ?>
</ul>
<a href="#" class="select-list-expand" style="display: none;"><?php echo $this->translate('See more'); ?> <span class="select-list-hidden-count"></span></a>
<a href="#" class="select-list-collapse" style="display: none;"><?php echo $this->translate('See less'); ?></a>
<?php endif; ?>
