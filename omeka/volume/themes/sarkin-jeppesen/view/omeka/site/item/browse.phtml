<?php
/**
 * Sarkin-Jeppesen — Item browse (chart card grid)
 *
 * Displays items as a grid of approach-chart-style cards,
 * inspired by Jeppesen terminal procedure index pages.
 *
 * When accessed via /item-set/{id}, redirects to the faceted browse
 * page with that item set pre-selected instead of showing a plain list.
 */

// Redirect item-set show to faceted browse with set pre-selected (if module active)
if (isset($itemSet)):
    try {
        $fbPageId     = 2;
        $fbCategoryId = 2;
        $fbBaseUrl = $this->url('site/faceted-browse', [
            'site-slug' => $this->currentSite()->slug(),
            'page-id'   => $fbPageId,
        ]);
        $redirectUrl = $fbBaseUrl . '?item_set_id[]=' . (int)$itemSet->id()
            . '&faceted_browse_category_id=' . (int)$fbCategoryId;
        echo '<script>window.location.replace(' . json_encode($redirectUrl) . ');</script>';
        echo '<p>Redirecting to <a href="' . $this->escapeHtml($redirectUrl) . '">browse</a>…</p>';
        return;
    } catch (\Exception $e) { /* FacetedBrowse not installed — fall through to default browse */ }
endif;

$escape    = $this->plugin('escapeHtml');
$translate = $this->plugin('translate');

$this->htmlElement('body')->appendAttribute('class', 'item browse');

$layoutSetting = $this->themeSetting('browse_layout') ?: 'grid';
$isGrid = ($layoutSetting === 'grid');

// Property helper
$val = function ($item, $term, $fallback = "\xE2\x80\x94") use ($escape) {
    $v = $item->value($term, ['default' => null]);
    return $v ? $escape((string) $v) : $fallback;
};

// Reject EXIF timestamps and MIME types from auto-populated fields
$isArtworkDate = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '' || $str === "\xE2\x80\x94") return false;
    if (preg_match('/^\d{4}:\d{2}:\d{2}/', $str)) return false;
    if (preg_match('/\d{4}-\d{2}-\d{2}T/', $str)) return false;
    return true;
};
$isNotMime = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '' || $str === "\xE2\x80\x94") return false;
    if (preg_match('#^[\w-]+/[\w.+-]+$#', $str)) return false;
    return true;
};
?>

<?php
$fulltextSearch = $this->params()->fromQuery('fulltext_search');
$totalResults = $this->plugin('pagination')->getPaginator()->getTotalCount();
// Strip whitespace + any surrounding straight or curly quotes so a search like
// `"Robert Johnson"` doesn't render as `... for ""Robert Johnson""`.
$fulltextSearchDisplay = $fulltextSearch !== null
    ? trim((string) $fulltextSearch, " \t\n\r\0\x0B\"'\xE2\x80\x9C\xE2\x80\x9D\xE2\x80\x98\xE2\x80\x99")
    : '';
$pageTitleText  = $fulltextSearch
    ? sprintf('%d %s for "%s"', $totalResults, $totalResults === 1 ? 'result' : 'results', ucwords($fulltextSearchDisplay))
    : $translate('Index of Works');
?>
<div class="page-title-row<?php echo $fulltextSearch ? ' page-title-row--search' : ''; ?>">
    <h1><?php echo $escape($pageTitleText); ?></h1>
    <span class="subtitle"><?php echo $escape($this->paginationInfo ?? ''); ?></span>
</div>

<?php // TEMP — search-filters strip ("Search full-text: X") suppressed; the page title above covers the fulltext case. Restore $this->searchFilters() in a future phase if multi-filter visualization is needed. ?>

<?php // TEMP — sort selector + advanced-search link hidden for launch. Restore the .browse-controls block in a future phase. ?>

<?php $this->trigger('view.browse.before'); ?>

<?php if (count($items)): ?>
<ul class="chart-grid<?php echo $isGrid ? '' : ' list-view'; ?>">
    <?php foreach ($items as $item):
        $title   = $item->displayTitle() ?: 'Untitled';
        $dateRaw = $val($item, 'dcterms:date', '') ?: $val($item, 'schema:dateCreated', '');
        $date    = $isArtworkDate($dateRaw) ? $dateRaw : '';
        $catId   = $val($item, 'dcterms:identifier', '');
        $mediumRaw = $val($item, 'dcterms:medium', '');
        $medium  = $isNotMime($mediumRaw) ? $mediumRaw : '';
        $surface = $val($item, 'schema:artworkSurface', '');
        $mediumDisplay = $medium . ($surface ? ' on ' . strtolower($surface) : '');
        $height  = $val($item, 'schema:height', '');
        $width   = $val($item, 'schema:width', '');
        $extent  = $val($item, 'dcterms:extent', '');
        // Build dimensions from height × width, or fall back to extent — dual-unit via shared partial
        $dims = $this->partial('common/dimensions', [
            'height' => $height,
            'width'  => $width,
            'extent' => $extent,
        ]);

        $primaryMedia = $item->primaryMedia();
        $thumbUrl = $primaryMedia ? $primaryMedia->thumbnailUrl('large') : null;
    ?>
    <li class="chart-card" data-item-id="<?php echo (int) $item->id(); ?>">
        <a href="<?php echo $escape($item->url()); ?>">
            <div class="card-image">
                <?php if ($thumbUrl): ?>
                    <img src="<?php echo $escape($thumbUrl); ?>"
                         alt="<?php echo $escape($title); ?>"
                         loading="lazy" />
                <?php else: ?>
                    <div class="card-image-placeholder">No image</div>
                <?php endif; ?>
            </div>
            <div class="card-facts">
                <div class="card-fact">
                    <div class="card-fact-label">Year</div>
                    <div class="card-fact-value"><?php echo $date; ?></div>
                </div>
                <div class="card-fact">
                    <div class="card-fact-label">Size</div>
                    <div class="card-fact-value"><?php echo $dims ?: '—'; ?></div>
                </div>
            </div>
            <div class="card-info">
                <?php if ($catId): ?>
                    <div class="card-id"><?php echo $catId; ?></div>
                <?php endif; ?>
                <?php // TEMP — auto-generated titles ("brancusi 6", etc.) hidden because they're noise. Restore the .card-title div in a future phase if curated titles are added. ?>
                <?php if ($mediumDisplay): ?>
                    <div class="card-medium"><?php echo $mediumDisplay; ?></div>
                <?php endif; ?>
            </div>
        </a>
    </li>
    <?php endforeach; ?>
</ul>
<?php else: ?>
    <p><?php echo $translate('No items found.'); ?></p>
<?php endif; ?>

<?php $this->trigger('view.browse.after'); ?>

<?php echo $this->pagination(); ?>
