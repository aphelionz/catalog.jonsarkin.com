        </section>
        <?php endif; ?>
    </section>
    <?php endif; ?>

    <?php elseif ($isWriting): ?>
    <header class="record-header record-header--writing">
        <div>
            <div class="record-facts">
                <?php if ($date): ?>
                <div class="fact year">
                    <dl><dt>Published</dt><dd><?php echo $date; ?></dd></dl>
                </div>
                <?php endif; ?>
                <?php if ($sourceUrl):
