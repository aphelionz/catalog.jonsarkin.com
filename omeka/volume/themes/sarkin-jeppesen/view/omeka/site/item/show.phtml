        <?php endif; ?>

        <?php if (!empty($bibliography)): ?>
        <section aria-labelledby="person-bibliography-heading">
            <h3 id="person-bibliography-heading"><?php echo $translate('Bibliography'); ?></h3>
            <ul>
                <?php foreach ($bibliography as $bib): ?>
                    <li><?php echo $bib; ?></li>
                <?php endforeach; ?>
            </ul>
        </section>
        <?php endif; ?>

        <?php if (!empty($motifs)): ?>
        <section aria-labelledby="person-subjects-heading">
            <h3 id="person-subjects-heading"><?php echo $translate('Subjects & themes'); ?></h3>
            <ul class="genres">
                <?php foreach ($motifs as $motif): ?>
                    <li><?php echo $motif; ?></li>
                <?php endforeach; ?>
