<?php
/**
 * Sarkin-Jeppesen — Item detail (record page)
 *
 * Properties mapped per docs/metadata-mapping.md
 * No fallbacks — empty fields are omitted entirely.
 */
$escape    = $this->plugin('escapeHtml');
$translate = $this->plugin('translate');

$this->htmlElement('body')->appendAttribute('class', 'item show');

// ── Property helpers ──
// Single value — returns escaped string or empty string
$val = function ($term) use ($item, $escape) {
    $v = $item->value($term, ['default' => null]);
    return $v ? $escape(trim((string) $v)) : '';
};

// All values for a repeatable property
$allVals = function ($term) use ($item, $escape) {
    $values = $item->value($term, ['all' => true, 'default' => []]);
    $result = [];
    foreach ($values as $v) {
        $str = trim((string) $v);
        if ($str !== '') $result[] = $escape($str);
    }
    return $result;
};

// Reject EXIF timestamps — e.g. "2026:03:02 11:47:51"
$isArtworkDate = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '') return false;
    if (preg_match('/^\d{4}:\d{2}:\d{2}/', $str)) return false;   // EXIF
    if (preg_match('/\d{4}-\d{2}-\d{2}T/', $str)) return false;   // ISO datetime
    return true;
};

// Reject MIME types — e.g. "image/jpeg"
$isNotMime = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '') return false;
    if (preg_match('#^[\w-]+/[\w.+-]+$#', $str)) return false;
    return true;
};

// ── Identity ──
$dateRaw    = $val('dcterms:date') ?: $val('schema:dateCreated');
$date       = ($dateRaw && $isArtworkDate($dateRaw)) ? $dateRaw : '';
// Creator may be a linked resource (URI) — resolve to display title
$creatorVal = $item->value('dcterms:creator', ['default' => null])
           ?: $item->value('schema:creator', ['default' => null]);
if ($creatorVal) {
    $vr = $creatorVal->valueResource();
    $creator = $vr ? $escape($vr->displayTitle()) : $escape(trim((string) $creatorVal));
} else {
    $creator = '';
}
$identifier = $val('dcterms:identifier');
$type       = $val('dcterms:type');

// ── Type detection ──
$resourceTemplate = $item->resourceTemplate();
$isWriting = ($resourceTemplate && $resourceTemplate->id() === 3);
$resourceClass = $item->resourceClass();
$isPerson  = ($resourceClass && $resourceClass->id() === 119); // schema:Person
$isExhibition = ($resourceClass && $resourceClass->id() === 879); // schema:ExhibitionEvent
$genre     = $val('schema:genre');
$fullText  = $val('bibo:content');

// ── Canonical Jon Sarkin Person reference (reused across JSON-LD branches) ──
// sameAs links Wikipedia, Wikidata, and authority files so Google can disambiguate
// the creator across the knowledge graph. Identifiers sourced from Wikidata Q16185574.
$sarkinPersonRef = [
    '@type'     => 'Person',
    'name'      => 'Jon Sarkin',
    'birthDate' => '1953-04-27',
    'deathDate' => '2024-07-19',
    'sameAs'    => [
        'https://en.wikipedia.org/wiki/Jon_Sarkin',
        'https://www.wikidata.org/wiki/Q16185574',
        'https://viaf.org/viaf/15968039',
        'https://id.loc.gov/authorities/names/n2010078960',
        'https://id.oclc.org/worldcat/entity/E39PBJxwxprWQxJsfwGMPDQq',
    ],
];
$sourceUrl  = $val('dcterms:source');
$shopifyUrl = $val('schema:url');

// ── Physical ──
$mediumVals = array_filter($allVals('dcterms:medium'), $isNotMime);
$medium     = implode(', ', $mediumVals);
$formatRaw  = $val('dcterms:format');
$format     = ($formatRaw && $isNotMime($formatRaw)) ? $formatRaw : '';
$surface    = $val('schema:artworkSurface');
$height     = $val('schema:height');
$width      = $val('schema:width');
$signed     = $val('schema:distinguishingSign');
$condition  = $val('schema:itemCondition');
$extent     = $val('dcterms:extent');

// Build dimensions string — dual-unit (inches + cm) via shared partial
$dimensions = $this->partial('common/dimensions', [
    'height' => $height,
    'width'  => $width,
    'extent' => $extent,
]);

// No medium→format fallback: format (framing) and medium are distinct fields

// Combined medium + support for SEO (e.g. "Marker on foamcore")
$mediumFull = $medium;
if ($medium && $surface) $mediumFull = $medium . ' on ' . strtolower(strip_tags($surface));
elseif ($surface) $mediumFull = strip_tags($surface);

// Build display labels
if ($isPerson) {
    $pageLabel = $item->displayTitle() ?: ('Item #' . $item->id());
    $pageLabelLong = $pageLabel;
} elseif ($isExhibition) {
    $pageLabel = $item->displayTitle() ?: ('Exhibition #' . $item->id());
    $pageLabelLong = $pageLabel;
    $venue = $val('schema:location');
    $exhibitionType = $type; // Solo or Group
    if ($venue) $pageLabelLong .= ' — ' . strip_tags($venue);
    if ($date)  $pageLabelLong .= ', ' . strip_tags($date);
} elseif ($isWriting) {
    // Writings have real titles
    $pageLabel = $item->displayTitle() ?: ($identifier ?: ('Item #' . $item->id()));
    $pageLabelLong = $pageLabel;
    if ($genre) $pageLabelLong .= ' · ' . strip_tags($genre);
    if ($date)  $pageLabelLong .= ', ' . strip_tags($date);
} else {
    // Artworks are untitled — build display labels from catalog number + medium + date
    $pageLabel = $identifier ?: ('Item #' . $item->id());
    $pageLabelLong = $pageLabel;
    if ($mediumFull) $pageLabelLong .= ' · ' . strip_tags($mediumFull);
    if ($date)   $pageLabelLong .= ', ' . strip_tags($date);
}

// ── Custody & Rights ──
$owner      = $val('bibo:owner');
$spatial    = $val('dcterms:spatial');
$rights     = $val('dcterms:rights');
$creditText = $val('schema:creditText');

// ── Permanent Collection designation ──
$isPermanentCollection = false;
foreach ($item->itemSets() as $set) {
    if ($set->displayTitle() === 'Permanent Collection') {
        $isPermanentCollection = true;
        break;
    }
}

// Provenance (repeatable)
$provenanceVals = $allVals('dcterms:provenance');

// ── Documentation ──
$inscriptions    = $allVals('bibo:annotates');
$transcriptionRaw = $val('bibo:content');
$transcription   = in_array(strtolower(trim(strip_tags($transcriptionRaw))), ['∅', 'no text', ''], true) ? '' : $transcriptionRaw;
$exhibitionVals  = $item->value('bibo:presentedAt', ['all' => true, 'default' => []]);
$exhibitions     = $allVals('bibo:presentedAt');
$bibliography    = $allVals('dcterms:bibliographicCitation');
$description     = $val('dcterms:description');

// ── Collector layer ──
$motifs          = $allVals('dcterms:subject');
$displayCare     = $val('curation:note');

// ── Media ──
$primaryMedia = $item->primaryMedia();
$allMedia     = $item->media();
$isVideo      = $primaryMedia && strpos($primaryMedia->mediaType(), 'video/') === 0;
$imageUrl     = $primaryMedia ? ($primaryMedia->originalUrl() ?: $primaryMedia->thumbnailUrl('large')) : '';

$extraMedia = [];
foreach ($allMedia as $m) {
    if ($primaryMedia && $m->id() === $primaryMedia->id()) continue;
    $extraMedia[] = $m;
}

// ── SEO: title, meta description, Open Graph, Twitter Card, canonical ──
$this->headTitle(strip_tags($pageLabelLong) . ' — Jon Sarkin');

if ($isPerson) {
    $metaDesc = strip_tags($pageLabel) . ' — artist biography, photographs, exhibition history. Jon Sarkin Catalog Raisonné.';
} elseif ($isExhibition) {
    $metaDesc = strip_tags($pageLabel)
        . ($venue ? '. ' . strip_tags($venue) : '')
        . ($date ? " ($date)" : '')
        . '. Exhibition history — Jon Sarkin Catalog Raisonné.';
} elseif ($isWriting) {
    $metaDesc = ($creator ?: 'Jon Sarkin') . '. ' . strip_tags($pageLabel)
        . ($genre ? ". $genre" : '')
        . ($date ? " ($date)" : '')
        . '. From the Jon Sarkin Catalog Raisonné.';
} else {
    $metaDesc = ($creator ?: 'Jon Sarkin') . '. ' . strip_tags($pageLabel)
        . ($mediumFull ? '. ' . strip_tags($mediumFull) : '')
        . ($date ? " ($date)" : '') . '.';
    if (!empty($motifs)) {
        $metaDesc .= ' ' . implode(', ', array_map('strip_tags', array_slice($motifs, 0, 3))) . '.';
    }
    $metaDesc .= ' From the Jon Sarkin Catalog Raisonné.';
}
$this->headMeta()->appendName('description', strip_tags($metaDesc));

$this->headMeta()->appendProperty('og:title', strip_tags($pageLabelLong) . ' — ' . ($creator ?: 'Jon Sarkin'));
$this->headMeta()->appendProperty('og:description', strip_tags($metaDesc));
$this->headMeta()->appendProperty('og:type', 'article');
$this->headMeta()->appendProperty('og:url', $this->serverUrl(true));
if ($imageUrl) {
    $this->headMeta()->appendProperty('og:image', $imageUrl);
}
$this->headMeta()->appendName('twitter:card', 'summary_large_image');

// Signal to layout.phtml that this page has already set its own OG meta — skip layout-level defaults.
$this->placeholder('item_og_set')->set(true);

$this->headLink(['rel' => 'canonical', 'href' => $this->serverUrl(true)]);

// ── Schema.org JSON-LD ──
if ($isPerson) {
    $jsonLd = $sarkinPersonRef;
    $jsonLd['@context'] = 'https://schema.org';
    $jsonLd['name']     = strip_tags($pageLabel);
    $jsonLd['jobTitle'] = 'Artist';
    if ($description) $jsonLd['description'] = html_entity_decode(strip_tags($description), ENT_QUOTES | ENT_HTML5, 'UTF-8');
    if ($imageUrl)    $jsonLd['image'] = $imageUrl;
    $jsonLd['url'] = $this->serverUrl(true);
} elseif ($isExhibition) {
    $jsonLd = [
        '@context'  => 'https://schema.org',
        '@type'     => 'ExhibitionEvent',
        'name'      => strip_tags($pageLabel),
    ];
    if ($date)  $jsonLd['startDate'] = strip_tags($date);
    if ($venue) $jsonLd['location'] = ['@type' => 'Place', 'name' => html_entity_decode(strip_tags($venue), ENT_QUOTES | ENT_HTML5, 'UTF-8')];
    if ($description) $jsonLd['description'] = html_entity_decode(strip_tags($description), ENT_QUOTES | ENT_HTML5, 'UTF-8');
    $jsonLd['about'] = $sarkinPersonRef;
    $jsonLd['url'] = $this->serverUrl(true);
} elseif ($isWriting) {
    $jsonLd = [
        '@context' => 'https://schema.org',
        '@type'    => 'Article',
        'name'     => strip_tags($pageLabel),
    ];
    if ($identifier) $jsonLd['identifier'] = strip_tags($identifier);
    $jsonLd['author'] = (!$creator || $creator === 'Jon Sarkin')
        ? $sarkinPersonRef
        : ['@type' => 'Person', 'name' => $creator];
    if ($date)       $jsonLd['datePublished'] = strip_tags($date);
    if ($genre)      $jsonLd['genre'] = strip_tags($genre);
    if ($fullText)   $jsonLd['articleBody'] = strip_tags($fullText);
    $jsonLd['copyrightHolder'] = [
        '@type' => 'Organization',
        'name' => 'The Jon Sarkin Estate',
        'url' => 'https://catalog.jonsarkin.com',
        'contactPoint' => [
            '@type' => 'ContactPoint',
            'contactType' => 'Estate Manager',
            'name' => 'Mark Henderson',
            'email' => 'art@jonsarkin.com',
        ],
    ];
    if ($creditText) $jsonLd['creditText'] = strip_tags($creditText);
    if ($sourceUrl)  $jsonLd['url'] = strip_tags($sourceUrl);
} else {
    $jsonLd = [
        '@context' => 'https://schema.org',
        '@type'    => 'VisualArtwork',
        'name'     => strip_tags($pageLabel),
    ];
    if ($identifier) $jsonLd['identifier'] = strip_tags($identifier);
    $jsonLd['creator'] = (!$creator || $creator === 'Jon Sarkin')
        ? $sarkinPersonRef
        : ['@type' => 'Person', 'name' => $creator];
    if ($date)       $jsonLd['dateCreated'] = strip_tags($date);
    if ($medium)     $jsonLd['artMedium'] = strip_tags($medium);
    if ($surface)    $jsonLd['artworkSurface'] = strip_tags($surface);
    if ($type)       $jsonLd['artform'] = strip_tags($type);
    // Dimensions as QuantitativeValue with explicit inch unit (UN/CEFACT INH).
    // Bare numbers are ambiguous; explicit unit supports dimensional search.
    if ($height && is_numeric(strip_tags($height))) {
        $jsonLd['height'] = ['@type' => 'QuantitativeValue', 'value' => (float) strip_tags($height), 'unitCode' => 'INH'];
    }
    if ($width && is_numeric(strip_tags($width))) {
        $jsonLd['width'] = ['@type' => 'QuantitativeValue', 'value' => (float) strip_tags($width), 'unitCode' => 'INH'];
    }
    // image: full array of media URLs (primary first), filtered to image MIME types.
    // Items with verso/detail shots surface all views in Google Images.
    $imageLd = [];
    if ($imageUrl && !$isVideo) $imageLd[] = $imageUrl;
    foreach ($extraMedia as $extraM) {
        if (strpos((string) $extraM->mediaType(), 'image/') !== 0) continue;
        $extraUrl = $extraM->originalUrl();
        if ($extraUrl) $imageLd[] = $extraUrl;
    }
    if (!empty($imageLd)) {
        $jsonLd['image'] = count($imageLd) === 1 ? $imageLd[0] : $imageLd;
    }
    $jsonLd['copyrightHolder'] = [
        '@type' => 'Organization',
        'name' => 'The Jon Sarkin Estate',
        'url' => 'https://catalog.jonsarkin.com',
        'contactPoint' => [
            '@type' => 'ContactPoint',
            'contactType' => 'Estate Manager',
            'name' => 'Mark Henderson',
            'email' => 'art@jonsarkin.com',
        ],
    ];
    if ($creditText) $jsonLd['creditText'] = strip_tags($creditText);
    if ($spatial)    $jsonLd['location'] = ['@type' => 'Place', 'name' => strip_tags($spatial)];

    // schema:mentions — people, works, films the artwork references. Values follow
    // the curated "Name [Type]" format (e.g. "Francisco Goya [Visual Artist]"). Type
    // bracket maps to the corresponding schema.org @type so Google sees structured
    // entity references, not just text.
    $mentionsTypeMap = [
        'Visual Artist'      => 'Person',
        'Musician'           => 'Person',
        'Historical Figure'  => 'Person',
        'Sports Figure'      => 'Person',
        'Writer'             => 'Person',
        'Literary Character' => 'Person',
        'Film'               => 'Movie',
        'Literary Work'      => 'Book',
        'Music Group'        => 'MusicGroup',
        'Place'              => 'Place',
    ];
    // Only emit values that match the curated "Name [Type]" format. Untyped values
    // (~50 in the whole catalog) are enrichment ruminations that leaked into the
    // field — long, sentence-shaped text that would be junk in JSON-LD.
    $mentionsLd = [];
    foreach ($allVals('schema:mentions') as $m) {
        $m = trim(strip_tags((string) $m));
        if (!preg_match('/^(.+?)\s*\[([^\]]+)\]\s*$/', $m, $match)) {
            continue;
        }
        $entityName = trim($match[1]);
        $entityType = $mentionsTypeMap[trim($match[2])] ?? 'Thing';
        if ($entityName !== '') {
            $mentionsLd[] = ['@type' => $entityType, 'name' => $entityName];
        }
    }
    if (!empty($mentionsLd)) {
        $jsonLd['mentions'] = $mentionsLd;
    }

    // subjectOf — exhibitions that featured this artwork. Links the artwork to
    // its exhibition history pages in the catalog (or text-only entries for
    // exhibitions not yet given their own item).
    $subjectOfLd = [];
    foreach ($exhibitionVals as $exVal) {
        $exRes = $exVal->valueResource();
        if ($exRes) {
            $subjectOfLd[] = [
                '@type' => 'ExhibitionEvent',
                'name'  => $exRes->displayTitle(),
                'url'   => 'https://catalog.jonsarkin.com/item/' . (int) $exRes->id(),
            ];
        } else {
            $exText = trim((string) $exVal);
            if ($exText !== '') {
                $subjectOfLd[] = ['@type' => 'ExhibitionEvent', 'name' => $exText];
            }
        }
    }
    if (!empty($subjectOfLd)) {
        $jsonLd['subjectOf'] = $subjectOfLd;
    }
}
$jsonLd['isPartOf'] = [
    '@type' => 'CreativeWork',
    'name'  => 'Jon Sarkin: Catalog Raisonné',
    'url'   => 'https://catalog.jonsarkin.com',
];
$jsonLd['mainEntityOfPage'] = $this->serverUrl(true);

// BreadcrumbList — gives Google site-structure context, can render in SERPs.
$breadcrumbParent = $isExhibition
    ? ['name' => 'Exhibitions', 'url' => 'https://catalog.jonsarkin.com/exhibitions']
    : ['name' => 'Browse',      'url' => 'https://catalog.jonsarkin.com/faceted-browse/2'];
$breadcrumbList = [
    '@context' => 'https://schema.org',
    '@type'    => 'BreadcrumbList',
    'itemListElement' => [
        [
            '@type'    => 'ListItem',
            'position' => 1,
            'name'     => $breadcrumbParent['name'],
            'item'     => $breadcrumbParent['url'],
        ],
        [
            '@type'    => 'ListItem',
            'position' => 2,
            'name'     => strip_tags($pageLabel),
        ],
    ],
];

// ── Linked Art JSON-LD (CIDOC-CRM profile) ──
// Parallel cultural-heritage data layer. Targets institutional aggregators
// and museum-side data consumers — Getty, Yale BAC, Europeana, the LUX
// project. Not direct SEO; an institutional credibility + interoperability
// signal that compounds with the schema.org block above.
//
// AAT URIs are stable Getty identifiers for the controlled vocabulary terms
// (work types, dimension types, units, identifier roles). Material entries
// emit with _label only — Sarkin's medium vocabulary doesn't cleanly map to
// AAT and forcing a mapping would introduce inaccurate authority claims.
$sarkinLinkedArtPerson = [
    'id'    => 'https://catalog.jonsarkin.com/item/3',
    'type'  => 'Person',
    '_label' => 'Jon Sarkin',
    'equivalent' => [
        ['id' => 'https://www.wikidata.org/wiki/Q16185574',                            'type' => 'Person', '_label' => 'Jon Sarkin'],
        ['id' => 'https://viaf.org/viaf/15968039',                                     'type' => 'Person', '_label' => 'Jon Sarkin'],
        ['id' => 'https://id.loc.gov/authorities/names/n2010078960',                   'type' => 'Person', '_label' => 'Jon Sarkin'],
        ['id' => 'https://id.oclc.org/worldcat/entity/E39PBJxwxprWQxJsfwGMPDQq',       'type' => 'Person', '_label' => 'Jon Sarkin'],
    ],
];

$linkedArt = null;
if ($isPerson && $item->id() === 3) {
    // Jon Sarkin (item 3) — full Person profile with born/died/activity.
    $linkedArt = $sarkinLinkedArtPerson;
    $linkedArt['@context'] = 'https://linked.art/ns/v1/linked-art.json';
    $linkedArt['id']       = $this->serverUrl(true);
    $linkedArt['born'] = [
        'type' => 'Birth',
        'timespan' => [
            'type'               => 'TimeSpan',
            'begin_of_the_begin' => '1953-04-27T00:00:00Z',
            'end_of_the_end'     => '1953-04-27T23:59:59Z',
            'identified_by'      => [['type' => 'Name', 'content' => '27 April 1953']],
        ],
        'took_place_at' => [['type' => 'Place', '_label' => 'Newark, New Jersey']],
    ];
    $linkedArt['died'] = [
        'type' => 'Death',
        'timespan' => [
            'type'               => 'TimeSpan',
            'begin_of_the_begin' => '2024-07-19T00:00:00Z',
            'end_of_the_end'     => '2024-07-19T23:59:59Z',
            'identified_by'      => [['type' => 'Name', 'content' => '19 July 2024']],
        ],
        'took_place_at' => [['type' => 'Place', '_label' => 'Gloucester, Massachusetts']],
    ];
    $linkedArt['professional_activity'] = [[
        'type' => 'Activity',
        'classified_as' => [[
            'id'     => 'http://vocab.getty.edu/aat/300025103',
            'type'   => 'Type',
            '_label' => 'artists',
        ]],
    ]];
    if ($imageUrl) {
        $linkedArt['representation'] = [['id' => $imageUrl, 'type' => 'VisualItem', '_label' => 'Portrait']];
    }
} elseif ($isPerson) {
    // Other Person items (Rhodes, Millionaire, Flaherty, etc.) — minimal profile.
    // Their authority identifiers aren't tracked in our catalog, so just name + ID.
    $linkedArt = [
        '@context' => 'https://linked.art/ns/v1/linked-art.json',
        'id'       => $this->serverUrl(true),
        'type'     => 'Person',
        '_label'   => strip_tags($pageLabel),
    ];
    if ($description) {
        $linkedArt['referred_to_by'] = [[
            'type'    => 'LinguisticObject',
            'content' => html_entity_decode(strip_tags($description), ENT_QUOTES | ENT_HTML5, 'UTF-8'),
            'classified_as' => [[
                'id'     => 'http://vocab.getty.edu/aat/300435422',
                'type'   => 'Type',
                '_label' => 'biography (general concept)',
            ]],
        ]];
    }
    if ($imageUrl) {
        $linkedArt['representation'] = [['id' => $imageUrl, 'type' => 'VisualItem']];
    }
} elseif (!$isExhibition && !$isWriting) {
    // VisualArtwork → HumanMadeObject
    $aatWorkType = [
        'Drawing'     => ['id' => 'http://vocab.getty.edu/aat/300033973', '_label' => 'drawings (visual works)'],
        'Painting'    => ['id' => 'http://vocab.getty.edu/aat/300033618', '_label' => 'paintings (visual works)'],
        'Collage'     => ['id' => 'http://vocab.getty.edu/aat/300033963', '_label' => 'collages (visual works)'],
        'Mixed Media' => ['id' => 'http://vocab.getty.edu/aat/300033777', '_label' => 'mixed media (visual works)'],
        'Sculpture'   => ['id' => 'http://vocab.getty.edu/aat/300047090', '_label' => 'sculpture (visual works)'],
        'Print'       => ['id' => 'http://vocab.getty.edu/aat/300041273', '_label' => 'prints (visual works)'],
    ];
    $linkedArt = [
        '@context' => 'https://linked.art/ns/v1/linked-art.json',
        'id'       => $this->serverUrl(true),
        'type'     => 'HumanMadeObject',
        '_label'   => strip_tags($pageLabel),
    ];
    $typeStr = strip_tags($type);
    if (isset($aatWorkType[$typeStr])) {
        $linkedArt['classified_as'] = [$aatWorkType[$typeStr] + ['type' => 'Type']];
    }
    if ($identifier) {
        $linkedArt['identified_by'] = [[
            'type'    => 'Identifier',
            'content' => strip_tags($identifier),
            'classified_as' => [[
                'id'     => 'http://vocab.getty.edu/aat/300404628',
                'type'   => 'Type',
                '_label' => 'accession numbers',
            ]],
        ]];
    }
    $productionLd = [
        'type' => 'Production',
        'carried_out_by' => [$sarkinLinkedArtPerson],
    ];
    if ($date && is_numeric(substr(strip_tags($date), 0, 4))) {
        $year = (int) substr(strip_tags($date), 0, 4);
        if ($year > 1900 && $year < 2100) {
            $productionLd['timespan'] = [
                'type'               => 'TimeSpan',
                'begin_of_the_begin' => "{$year}-01-01T00:00:00Z",
                'end_of_the_end'     => "{$year}-12-31T23:59:59Z",
                'identified_by'      => [['type' => 'Name', 'content' => (string) $year]],
            ];
        }
    }
    $linkedArt['produced_by'] = $productionLd;
    $madeOf = [];
    foreach ($mediumVals as $mv) {
        $mv = trim(strip_tags($mv));
        if ($mv !== '') $madeOf[] = ['type' => 'Material', '_label' => $mv];
    }
    if ($surface) $madeOf[] = ['type' => 'Material', '_label' => strip_tags($surface)];
    if (!empty($madeOf)) $linkedArt['made_of'] = $madeOf;
    $dimensionLd = [];
    if ($height && is_numeric(strip_tags($height))) {
        $dimensionLd[] = [
            'type'  => 'Dimension',
            'value' => (float) strip_tags($height),
