                    <?php if (!empty($inscriptions)): ?>
                    <section aria-labelledby="inscriptions-heading">
                        <h4 id="inscriptions-heading"><?php echo $translate('Inscriptions'); ?></h4>
                        <dl>
                            <?php foreach ($inscriptions as $insc): ?>
                                <dt>Inscription</dt><dd><?php echo $insc; ?></dd>
                            <?php endforeach; ?>
                        </dl>
                    </section>
                    <?php endif; ?>


                    <?php if (!empty($bibliography)): ?>
                    <section aria-labelledby="bibliography-heading">
                        <h4 id="bibliography-heading"><?php echo $translate('Bibliography'); ?></h4>
                        <ul>
                            <?php foreach ($bibliography as $bib): ?>
                                <li><?php echo $bib; ?></li>
                            <?php endforeach; ?>
                        </ul>
                    </section>
                    <?php endif; ?>

                    <?php if (!empty($extraMedia)): ?>
                    <section aria-labelledby="verso-details-heading">
                        <h4 id="verso-details-heading"><?php echo $translate('Verso and detail images'); ?></h4>
                        <div class="supporting-media">
                            <?php
                            $slotLabels = ['Verso', 'Detail 1', 'Detail 2'];
                            for ($i = 0; $i < min(3, count($extraMedia)); $i++):
                                $extraM = $extraMedia[$i];
                                $extraTitle = $extraM->displayTitle();
                                $hasRealTitle = ($extraTitle && $extraTitle !== $extraM->source());
                                $caption = $hasRealTitle ? $extraTitle : $slotLabels[$i];
                            ?>
                            <figure class="supporting-slot">
                                <?php if (strpos($extraM->mediaType(), 'video/') === 0): ?>
                                <video controls preload="metadata">
                                    <source src="<?php echo $escape($extraM->originalUrl()); ?>"
                                            type="<?php echo $escape($extraM->mediaType()); ?>" />
                                </video>
                                <?php else: ?>
                                <img src="<?php echo $escape($extraM->thumbnailUrl('large')); ?>"
                                     alt="<?php echo $escape($caption . ' for ' . ($creator ?: 'Jon Sarkin') . ", $pageLabel"); ?>" />
                                <?php endif; ?>
                                <figcaption><?php echo $escape($caption); ?></figcaption>
                            </figure>
                            <?php endfor; ?>
                        </div>
                    </section>
                    <?php endif; ?>
                </section>
            </div>
        </div>

    </section>
    <?php endif; ?>

    <!-- ═══ RECORD FOOTER ═══ -->
    <?php if ($rights): ?>
    <footer class="record-footer">
        <div><?php echo $rights; ?></div>
    </footer>
    <?php endif; ?>
    <?php endif; /* !$isPerson && !$isExhibition */ ?>

</article>

<?php
// Suppress Omeka's auto-generated JSON-LD (dumps full API object including
// raw transcription and internal classification into page source)
ob_start();
$this->trigger('view.show.after');
$afterHtml = ob_get_clean();
echo preg_replace('#<script\s+type="application/ld\+json">.*?</script>#s', '', $afterHtml);
?>
