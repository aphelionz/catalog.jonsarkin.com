<?php
/**
 * Sarkin-Jeppesen — Site-wide search results
 *
 * Bypasses the controller's hardcoded limit of 10 and performs its own
 * paginated API query so we get 12 results per page with full pagination.
 */
$escape    = $this->plugin('escapeHtml');
$translate = $this->plugin('translate');

$this->htmlElement('body')->appendAttribute('class', 'search-results');

// Reject EXIF timestamps from auto-populated date fields
$isArtworkDate = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '' || $str === "\xE2\x80\x94") return false;
    if (preg_match('/^\d{4}:\d{2}:\d{2}/', $str)) return false;
    if (preg_match('/\d{4}-\d{2}-\d{2}T/', $str)) return false;
    return true;
};

$val = function ($resource, $term, $fallback = '') use ($escape) {
    $v = $resource->value($term, ['default' => null]);
    return $v ? $escape((string) $v) : $fallback;
};

// ── Pagination params ──
$perPage = 12;
$page    = max(1, (int) $this->params()->fromQuery('page', 1));
$offset  = ($page - 1) * $perPage;

// ── Own paginated API query (bypasses controller's limit:10) ──
$siteId  = $this->currentSite()->id();
$apiResponse = $this->api()->search('items', [
    'fulltext_search' => $query,
    'site_id'         => $siteId,
    'limit'           => $perPage,
    'offset'          => $offset,
]);
$items      = $apiResponse->getContent();
$totalItems = $apiResponse->getTotalResults();
$totalPages = (int) ceil($totalItems / $perPage);

// ── Build pagination URL helper ──
$pageUrl = function ($p) use ($query) {
    return $this->url('site/resource', ['controller' => 'index', 'action' => 'search'], true)
         . '?' . http_build_query(['fulltext_search' => $query, 'page' => $p]);
};
?>

<div class="page-title-row">
    <h1><?php echo $translate('Search Results'); ?>: <?php echo $escape($query); ?></h1>
    <span class="subtitle"><?php echo $totalItems; ?> <?php echo $totalItems === 1 ? 'result' : 'results'; ?></span>
</div>

<?php $this->trigger('view.search.before'); ?>

<?php if (count($items)): ?>
<ul class="chart-grid">
    <?php foreach ($items as $item):
        $title   = $item->displayTitle() ?: 'Untitled';
        $dateRaw = $val($item, 'dcterms:date', '') ?: $val($item, 'schema:dateCreated', '');
        $date    = $isArtworkDate($dateRaw) ? $dateRaw : '';
        $catId   = $val($item, 'dcterms:identifier');
        $height  = $val($item, 'schema:height', '');
        $width   = $val($item, 'schema:width', '');
        $extent  = $val($item, 'dcterms:extent', '');
        if ($height && $width) {
            $dims = $height . ' × ' . $width;
        } elseif ($extent) {
            $dims = $extent;
        } else {
            $dims = '';
        }
        $primaryMedia = $item->primaryMedia();
        $thumbUrl = $primaryMedia ? $primaryMedia->thumbnailUrl('large') : null;
    ?>
    <li class="chart-card">
        <a href="<?php echo $escape($item->url()); ?>">
            <div class="card-image">
                <?php if ($thumbUrl): ?>
                    <img src="<?php echo $escape($thumbUrl); ?>"
                         alt="<?php echo $escape($title); ?>"
                         loading="lazy" />
                <?php else: ?>
                    <div class="card-image-placeholder">No image</div>
                <?php endif; ?>
            </div>
            <div class="card-facts">
                <div class="card-fact">
                    <div class="card-fact-label">Year</div>
                    <div class="card-fact-value"><?php echo $date ?: '—'; ?></div>
                </div>
                <div class="card-fact">
                    <div class="card-fact-label">Size</div>
                    <div class="card-fact-value"><?php echo $dims ?: "\xE2\x80\x94"; ?></div>
                </div>
            </div>
            <div class="card-info">
                <div class="card-title"><?php echo $catId ?: $escape($title); ?></div>
            </div>
        </a>
    </li>
    <?php endforeach; ?>
</ul>

<?php if ($totalPages > 1): ?>
<nav class="pagination" aria-label="<?php echo $translate('Pagination'); ?>">
    <?php if ($page > 1): ?>
        <a href="<?php echo $escape($pageUrl($page - 1)); ?>">&larr; Prev</a>
    <?php endif; ?>
    <span>Page <?php echo $page; ?> of <?php echo $totalPages; ?></span>
    <?php if ($page < $totalPages): ?>
        <a href="<?php echo $escape($pageUrl($page + 1)); ?>">Next &rarr;</a>
    <?php endif; ?>
</nav>
<?php endif; ?>

<?php else: ?>
    <p><?php echo $translate('No items found.'); ?></p>
<?php endif; ?>

<?php $this->trigger('view.search.after'); ?>
