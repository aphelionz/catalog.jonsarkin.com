<?php
/**
 * Sarkin-Jeppesen — Site search redirect
 *
 * Search has been consolidated to the item browse route. This template
 * catches anything still hitting /search (old bookmarks, external links)
 * and forwards to /item?fulltext_search=... where the polished
 * results template (browse.phtml) lives.
 *
 * Both ?query= (Omeka core convention) and ?fulltext_search= (theme
 * convention) are accepted on entry.
 */
$escape = $this->plugin('escapeHtml');

$incoming = $this->params()->fromQuery('fulltext_search');
if ($incoming === null || $incoming === '') {
    $incoming = $this->params()->fromQuery('query', '');
}

$base = $this->url(
    'site/resource',
    ['controller' => 'item', 'action' => 'browse'],
    true
);
$redirectUrl = $incoming !== ''
    ? $base . '?' . http_build_query(['fulltext_search' => $incoming])
    : $base;
?>
<meta http-equiv="refresh" content="0; url=<?php echo $escape($redirectUrl); ?>">
<script>window.location.replace(<?php echo json_encode($redirectUrl); ?>);</script>
<p>Redirecting to <a href="<?php echo $escape($redirectUrl); ?>">search results</a>…</p>
