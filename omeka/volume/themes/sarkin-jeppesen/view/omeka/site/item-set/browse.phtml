<?php
/**
 * Sarkin-Jeppesen — Item-set browse
 *
 * Lists collections in the Jeppesen index style —
 * bold names, bordered entries, like a table of contents.
 *
 * Each collection links to the faceted browse page with that
 * item set pre-selected, rather than the default item-set show page.
 */
$escape    = $this->plugin('escapeHtml');
$translate = $this->plugin('translate');

// FacetedBrowse IDs (from faceted_browse_* tables)
$fbPageId     = 2;
$fbCategoryId = 2;
$fbBaseUrl = $this->url('site/faceted-browse', [
    'site-slug' => $this->currentSite()->slug(),
    'page-id'   => $fbPageId,
]);

$this->htmlElement('body')->appendAttribute('class', 'item-set browse');

// Use dcterms:type filter value as heading if present
$pageTitle = 'Collections';
$params = $this->params()->fromQuery();
if (!empty($params['property'])) {
    foreach ($params['property'] as $p) {
        if (isset($p['property']) && in_array($p['property'], ['8', 'dcterms:type', 'dcterms%3Atype'])
            && !empty($p['text'])) {
            $pageTitle = $p['text'] . 's';
            break;
        }
    }
}
?>

<div class="page-title-row">
    <h1><?php echo $escape($pageTitle); ?></h1>
</div>

<?php $this->trigger('view.browse.before'); ?>

<?php if (count($itemSets)): ?>
<ul class="item-set-list">
    <?php foreach ($itemSets as $itemSet):
        $thumb = $itemSet->thumbnail();
        $thumbUrl = $thumb ? $thumb->assetUrl() : null;
        // Fallback: use the first item's primary media thumbnail
        if (!$thumbUrl) {
            $items = $this->api()->search('items', ['item_set_id' => $itemSet->id(), 'per_page' => 1, 'has_media' => true])->getContent();
            if ($items) {
                $media = $items[0]->primaryMedia();
                if ($media) $thumbUrl = $media->thumbnailUrl('medium');
            }
        }
        $desc = $itemSet->value('dcterms:description', ['default' => null]);
        $href = $fbBaseUrl . '?' . http_build_query([
            'item_set_id' => [$itemSet->id()],
            'faceted_browse_category_id' => $fbCategoryId,
        ]);
    ?>
    <li class="item-set-entry">
        <a href="<?php echo $escape($href); ?>">
            <?php if ($thumbUrl): ?>
                <img src="<?php echo $escape($thumbUrl); ?>"
                     alt="<?php echo $escape($itemSet->displayTitle()); ?>"
                     loading="lazy" />
            <?php else: ?>
                <span class="item-set-placeholder"></span>
            <?php endif; ?>
            <span class="item-set-label">
                <span class="item-set-title"><?php echo $escape($itemSet->displayTitle()); ?></span>
                <?php if ($desc): ?>
                    <span class="item-set-desc"><?php echo $escape((string) $desc); ?></span>
                <?php endif; ?>
                <span class="item-set-count"><?php echo $itemSet->itemCount(); ?> works</span>
            </span>
        </a>
    </li>
    <?php endforeach; ?>
</ul>
<?php else: ?>
    <p><?php echo $translate('No collections found.'); ?></p>
<?php endif; ?>

<?php $this->trigger('view.browse.after'); ?>

<?php echo $this->pagination(); ?>
