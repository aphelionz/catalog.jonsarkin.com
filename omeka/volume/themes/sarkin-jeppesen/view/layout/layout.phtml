<?php
/**
 * Sarkin-Jeppesen — Master layout
 * Jeppesen manual-inspired wrapper for the Jon Sarkin Catalog Raisonne.
 */
$escape = $this->plugin('escapeHtml');
$site   = $this->site;

$this->htmlElement('html')->setAttribute('lang', $this->lang());
$this->headMeta()->setCharset('utf-8');
$this->headMeta()->appendName('viewport', 'width=device-width, initial-scale=1');
$this->headTitle($site->title())->setSeparator(' · ');

// Theme assets
$this->headLink()->prependStylesheet($this->assetUrl('css/style.css'), 'all');
// Omeka core icons (needed for admin bar)
$this->headLink()->appendStylesheet($this->assetUrl('css/iconfonts.css', 'Omeka'));

// jQuery + Omeka core
$this->headScript()->prependFile($this->assetUrl('vendor/jquery/jquery.min.js', 'Omeka'));
$this->headScript()->prependFile($this->assetUrl('js/global.js', 'Omeka'));
$this->jsTranslate();

// Theme JS (loaded at end of body)
$this->inlineScript()->appendFile($this->assetUrl('js/qrcode.min.js'));
$this->inlineScript()->appendFile($this->assetUrl('js/sarkin.js'));

$this->trigger('view.layout');

$footerText = $this->themeSetting('footer_text')
    ?: '&copy; ' . date('Y') . ', The Jon Sarkin Estate / Artists Rights Society (ARS), New York. All rights reserved.';

// Estate public key from ShieldedRegistryAssets ceremony
$sraPublicKey = null;
try {
    $sraResult = $this->setting('sra_ceremony_result');
    if (is_string($sraResult)) {
        $sraResult = json_decode($sraResult, true);
    }
    if (is_array($sraResult) && !empty($sraResult['pk_r'])) {
        $sraPublicKey = $sraResult['pk_r'];
    }
} catch (\Exception $e) { /* module not installed or setting missing */ }
?>
<!DOCTYPE html>
<?php echo $this->htmlElement('html'); ?>
<head>
    <?php echo $this->headMeta(); ?>
    <?php echo $this->headTitle(); ?>
    <?php echo $this->headLink(); ?>
    <?php echo $this->headStyle(); ?>
    <?php echo $this->headScript(); ?>
</head>

<?php echo $this->htmlElement('body'); ?>
    <a id="skipnav" href="#content" class="sr-only"><?php echo $this->translate('Skip to main content'); ?></a>

    <?php echo $this->userBar(); ?>

    <div class="site-wrapper">
        <header class="site-header">
            <a href="<?php echo $escape($site->url()); ?>" class="site-title-link">
                <?php echo $escape($site->title()); ?>
            </a>
            <form class="site-search" action="<?php echo $this->url('site/resource', ['controller' => 'index', 'action' => 'search'], true); ?>">
                <input type="text" name="fulltext_search" placeholder="Search" aria-label="Search" />
                <button type="submit" aria-label="Search">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </button>
            </form>
            <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">
                <span></span><span></span><span></span>
            </button>
        </header>

        <nav id="site-nav" class="site-nav" aria-label="<?php echo $this->translate('Primary navigation'); ?>">
            <?php echo $site->publicNav()->menu()->renderMenu(null, [
                'maxDepth' => 0,
            ]); ?>
        </nav>

        <main id="content" role="main">
            <?php echo $this->content; ?>
        </main>

        <footer class="site-footer">
            <div class="footer-line">
                <p><?php echo $footerText; ?></p>
                <nav class="footer-links" aria-label="Footer">
                    <a href="<?php echo $this->url('site/page', ['site-slug' => $site->slug(), 'page-slug' => 'rights']); ?>">Rights &amp; Reproduction</a>
                    <a href="<?php echo $this->url('site/page', ['site-slug' => $site->slug(), 'page-slug' => 'contact']); ?>">Contact</a>
                </nav>
            </div>
            <?php if ($sraPublicKey): ?>
            <p class="estate-key">Estate public key: <code><?php echo $escape($sraPublicKey); ?></code></p>
            <?php endif; ?>
        </footer>
    </div>

    <?php echo $this->inlineScript(); ?>
</body>
</html>
