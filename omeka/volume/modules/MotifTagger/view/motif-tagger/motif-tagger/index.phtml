<script>
(function() {
    // --- Footer offset to respect admin sidebar ---
    var contentEl = document.getElementById('content');
    if (contentEl) {
        var setFooterLeft = function() {
            document.documentElement.style.setProperty('--mt-content-left', contentEl.getBoundingClientRect().left + 'px');
        };
        setFooterLeft();
        window.addEventListener('resize', setFooterLeft);
    }

    // --- Tabs ---
    document.querySelectorAll('.mt-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.mt-tab').forEach(function(t) { t.classList.remove('active'); });
            document.querySelectorAll('.mt-tab-panel').forEach(function(p) { p.classList.remove('active'); });
            tab.classList.add('active');
            document.querySelector('[data-panel="' + tab.dataset.tab + '"]').classList.add('active');
        });
    });

    var searchUrl = <?= json_encode($searchUrl) ?>;
    var tagUrl = <?= json_encode($tagUrl) ?>;
    var addTermUrl = <?= json_encode($addTermUrl) ?>;
    var ingestClipUrl = <?= json_encode($ingestClipUrl) ?>;
    var ingestDinoUrl = <?= json_encode($ingestDinoUrl) ?>;
    var ingestSegmentsUrl = <?= json_encode($ingestSegmentsUrl) ?>;
    var densityUrl = <?= json_encode($densityUrl) ?>;
    var densityOverrideUrlTpl = <?= json_encode($densityOverrideUrl) ?>;

    var currentFile = null;
    var matches = [];

    // DOM refs
    var dropzone = document.getElementById('mt-dropzone');
    var fileInput = document.getElementById('mt-file-input');
    var refPreview = document.getElementById('mt-reference-preview');
    var refImg = document.getElementById('mt-reference-img');
    var clearBtn = document.getElementById('mt-clear-btn');
    var limitInput = document.getElementById('mt-limit');
    var thresholdInput = document.getElementById('mt-threshold');
    var thresholdVal = document.getElementById('mt-threshold-val');
    var searchBtn = document.getElementById('mt-search-btn');
    var searchStatus = document.getElementById('mt-search-status');

    var resultsSection = document.getElementById('mt-results-section');
    var resultsGrid = document.getElementById('mt-results-grid');
    var selectAllBtn = document.getElementById('mt-select-all');
    var deselectAllBtn = document.getElementById('mt-deselect-all');
    var matchCount = document.getElementById('mt-match-count');

    var footer = document.getElementById('mt-footer');
    var motifSelect = document.getElementById('mt-motif-select');
    var newTermInput = document.getElementById('mt-new-term');
    var addTermBtn = document.getElementById('mt-add-term-btn');
    var selectedCount = document.getElementById('mt-selected-count');
    var tagBtn = document.getElementById('mt-tag-btn');
    var tagStatus = document.getElementById('mt-tag-status');

    // --- Upload ---
    dropzone.addEventListener('click', function() { fileInput.click(); });
    fileInput.addEventListener('change', function() {
        if (fileInput.files.length) handleFile(fileInput.files[0]);
    });
    dropzone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropzone.classList.add('dragover');
    });
    dropzone.addEventListener('dragleave', function() {
        dropzone.classList.remove('dragover');
    });
    dropzone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropzone.classList.remove('dragover');
        if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
    });

    function handleFile(file) {
        if (!file.type.match(/^image\/(jpeg|png|webp)$/)) {
            setSearchStatus('Invalid file type. Use JPEG, PNG, or WebP.', true);
            return;
        }
        if (file.size > 10 * 1024 * 1024) {
            setSearchStatus('Image too large (max 10 MB).', true);
            return;
        }
        currentFile = file;
        refImg.src = URL.createObjectURL(file);
        refPreview.style.display = 'flex';
        dropzone.style.display = 'none';
        searchBtn.disabled = false;
        setSearchStatus('');
    }

    clearBtn.addEventListener('click', function() {
        currentFile = null;
        refPreview.style.display = 'none';
        dropzone.style.display = '';
        searchBtn.disabled = true;
        fileInput.value = '';
        if (refImg.src.startsWith('blob:')) URL.revokeObjectURL(refImg.src);
    });

    // --- Threshold ---
    thresholdInput.addEventListener('input', function() {
        thresholdVal.textContent = parseFloat(this.value).toFixed(2);
        applyThresholdFilter();
    });

    function applyThresholdFilter() {
        var threshold = parseFloat(thresholdInput.value);
        var cards = resultsGrid.querySelectorAll('.mt-card');
        var visible = 0;
        cards.forEach(function(card) {
            var score = parseFloat(card.dataset.score);
            if (score >= threshold) {
                card.classList.remove('mt-hidden');
                visible++;
            } else {
                card.classList.add('mt-hidden');
                card.querySelector('.mt-card-checkbox').checked = false;
                card.classList.remove('mt-checked');
            }
        });
        matchCount.textContent = visible + ' of ' + matches.length + ' results shown';
        setSearchStatus(visible + ' results found' + (visible < matches.length ? ' (' + matches.length + ' before threshold)' : ''));
        updateSelectedCount();
    }

    // --- Search ---
    searchBtn.addEventListener('click', doSearch);

    function doSearch() {
        if (!currentFile) return;
        searchBtn.disabled = true;
        setSearchStatus('<span class="mt-spinner"></span> Searching...', false);

        var fd = new FormData();
        fd.append('image', currentFile);
        fd.append('limit', limitInput.value);
        fd.append('search_mode', document.getElementById('mt-search-mode').value);

        fetch(searchUrl, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                searchBtn.disabled = false;
                if (data.error) {
                    setSearchStatus(data.error, true);
                    return;
                }
                matches = data.matches || [];
                renderResults();
            })
            .catch(function(e) {
                searchBtn.disabled = false;
                setSearchStatus('Request failed: ' + e.message, true);
            });
    }

    function setSearchStatus(msg, isError) {
        searchStatus.innerHTML = msg;
        searchStatus.className = isError ? 'error' : '';
    }

    // --- Results ---
    function renderResults() {
        resultsGrid.innerHTML = '';
        if (!matches.length) {
            resultsSection.style.display = 'none';
            footer.style.display = 'none';
            return;
        }

        resultsSection.style.display = '';
        footer.style.display = 'flex';

        matches.forEach(function(m) {
            var score = parseFloat(m.score) || 0;
            var scoreClass = score >= 0.8 ? 'high' : score >= 0.6 ? 'medium' : 'low';
            var pct = (score * 100).toFixed(1);
            var title = m.title || 'Untitled';
            var existingMotifs = (m.existing_motifs || []).join(', ');
            var adminUrl = '/admin/item/' + m.omeka_id + '/edit';

            var card = document.createElement('div');
            card.className = 'mt-card';
            card.dataset.id = m.omeka_id;
            card.dataset.score = score;

            var segThumbHtml = m.segment_url
                ? '<img class="mt-segment-thumb" src="' + escHtml(m.segment_url) + '" alt="segment">'
                : '';

            card.innerHTML =
                '<input type="checkbox" class="mt-card-checkbox" checked>' +
                '<div class="mt-card-img-wrap">' +
                    '<img src="' + escHtml(m.thumb_url || '') + '" loading="lazy" alt="' + escHtml(title) + '">' +
                    segThumbHtml +
                '</div>' +
                '<div class="mt-card-info">' +
                    '<span class="mt-score ' + scoreClass + '">' + pct + '%</span> ' +
                    '<span class="mt-catalog-num">' + escHtml(title) + '</span>' +
                    '<div class="mt-existing-motifs" title="' + escHtml(existingMotifs) + '">' +
                        (existingMotifs || '<em>no motifs</em>') +
                    '</div>' +
                '</div>';

            // Click thumbnail to open admin edit
            card.querySelector('.mt-card-img-wrap').addEventListener('click', function(e) {
                window.open(adminUrl, '_blank');
            });

            // Checkbox state
            var cb = card.querySelector('.mt-card-checkbox');
            card.classList.add('mt-checked');
            cb.addEventListener('change', function() {
                card.classList.toggle('mt-checked', cb.checked);
                updateSelectedCount();
            });

            resultsGrid.appendChild(card);
        });

        applyThresholdFilter();
    }

    // --- Select All / Deselect ---
    selectAllBtn.addEventListener('click', function() {
        resultsGrid.querySelectorAll('.mt-card:not(.mt-hidden) .mt-card-checkbox').forEach(function(cb) {
            cb.checked = true;
            cb.closest('.mt-card').classList.add('mt-checked');
        });
        updateSelectedCount();
    });

    deselectAllBtn.addEventListener('click', function() {
        resultsGrid.querySelectorAll('.mt-card-checkbox').forEach(function(cb) {
            cb.checked = false;
            cb.closest('.mt-card').classList.remove('mt-checked');
        });
        updateSelectedCount();
    });

    function updateSelectedCount() {
        var count = resultsGrid.querySelectorAll('.mt-card:not(.mt-hidden) .mt-card-checkbox:checked').length;
        selectedCount.textContent = count + ' selected';
        tagBtn.disabled = count === 0 || !motifSelect.value;
    }

    motifSelect.addEventListener('change', function() {
        tagBtn.disabled = !motifSelect.value || getSelectedIds().length === 0;
    });

    // --- Tagging ---
    tagBtn.addEventListener('click', doTag);

    function getSelectedIds() {
        var ids = [];
        resultsGrid.querySelectorAll('.mt-card:not(.mt-hidden) .mt-card-checkbox:checked').forEach(function(cb) {
            ids.push(parseInt(cb.closest('.mt-card').dataset.id, 10));
        });
        return ids;
    }

    function doTag() {
        var ids = getSelectedIds();
        var motif = motifSelect.value;
        if (!ids.length || !motif) return;

        tagBtn.disabled = true;
        setTagStatus('<span class="mt-spinner"></span> Tagging ' + ids.length + ' items...', '');

        fetch(tagUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ item_ids: ids, motif: motif })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            tagBtn.disabled = false;
            if (data.error) {
                setTagStatus(data.error, 'error');
                return;
            }
            var msg = data.tagged + ' tagged';
            if (data.skipped) msg += ', ' + data.skipped + ' already had it';
            if (data.errors && data.errors.length) msg += ', ' + data.errors.length + ' errors';
            setTagStatus(msg, data.errors && data.errors.length ? 'error' : 'success');

            // Update existing motifs display on tagged cards
            ids.forEach(function(id) {
                var card = resultsGrid.querySelector('.mt-card[data-id="' + id + '"]');
                if (!card) return;
                var motifsEl = card.querySelector('.mt-existing-motifs');
                var current = motifsEl.textContent.trim();
                if (current === 'no motifs' || current === '') {
                    motifsEl.textContent = motif;
                } else if (current.toLowerCase().indexOf(motif.toLowerCase()) === -1) {
                    motifsEl.textContent = current + ', ' + motif;
                }
                motifsEl.title = motifsEl.textContent;
            });

            updateSelectedCount();
        })
        .catch(function(e) {
            tagBtn.disabled = false;
            setTagStatus('Request failed: ' + e.message, 'error');
        });
    }

    function setTagStatus(msg, cls) {
        tagStatus.innerHTML = msg;
        tagStatus.className = cls || '';
    }

    // --- Add Term ---
    addTermBtn.addEventListener('click', doAddTerm);
    newTermInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') doAddTerm();
    });

    function doAddTerm() {
        var term = newTermInput.value.trim();
        if (!term) return;

        addTermBtn.disabled = true;
        fetch(addTermUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ term: term })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            addTermBtn.disabled = false;
            if (data.error) {
                setTagStatus(data.error, 'error');
                return;
            }
            // Rebuild dropdown from sorted terms
            var current = motifSelect.value;
            motifSelect.innerHTML = '<option value="">-- Select motif --</option>';
            (data.terms || []).forEach(function(t) {
                var opt = document.createElement('option');
                opt.value = t;
                opt.textContent = t;
                motifSelect.appendChild(opt);
            });
            // Select the newly added term
            motifSelect.value = data.added;
            newTermInput.value = '';
            setTagStatus('Added "' + data.added + '"', 'success');
            updateSelectedCount();
        })
        .catch(function(e) {
            addTermBtn.disabled = false;
            setTagStatus('Failed to add term: ' + e.message, 'error');
        });
    }

    // --- Ingestion ---
    var ingestStatus = document.getElementById('mt-ingest-status');
    var ingestClipBtn = document.getElementById('mt-ingest-clip-btn');
    var ingestDinoBtn = document.getElementById('mt-ingest-dino-btn');

    function dispatchIngest(url, label, btn) {
        btn.disabled = true;
        ingestStatus.textContent = 'Dispatching ' + label + ' job...';
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            if (data.error) {
                ingestStatus.textContent = 'Error: ' + data.error;
                ingestStatus.style.color = '#7a0b0b';
            } else {
                ingestStatus.textContent = label + ' job dispatched. Track progress in Jobs.';
                ingestStatus.style.color = '#2a7d2a';
            }
        })
        .catch(function(e) {
            btn.disabled = false;
            ingestStatus.textContent = 'Failed: ' + e.message;
            ingestStatus.style.color = '#7a0b0b';
        });
    }

    var ingestSegmentsBtn = document.getElementById('mt-ingest-segments-btn');

    ingestClipBtn.addEventListener('click', function() { dispatchIngest(ingestClipUrl, 'CLIP', ingestClipBtn); });
    ingestDinoBtn.addEventListener('click', function() { dispatchIngest(ingestDinoUrl, 'DINOv2', ingestDinoBtn); });
    ingestSegmentsBtn.addEventListener('click', function() { dispatchIngest(ingestSegmentsUrl, 'Segments', ingestSegmentsBtn); });

    // --- Density Tab ---
    var densityGrid = document.getElementById('mt-density-grid');
    var densityStatus = document.getElementById('mt-density-status');
    var densityPager = document.getElementById('mt-density-pager');
    var densityPrev = document.getElementById('mt-density-prev');
    var densityNext = document.getElementById('mt-density-next');
    var densityPageInfo = document.getElementById('mt-density-page-info');
    var densitySortSelect = document.getElementById('mt-density-sort');

    var densityState = { tier: '', sort: 'density_score', order: 'desc', page: 1, perPage: 50, total: 0, loaded: false };

    // Filter buttons
    document.querySelectorAll('.mt-filter-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.mt-filter-btn').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            densityState.tier = btn.dataset.tier;
            densityState.page = 1;
            loadDensity();
        });
    });

    // Sort
    densitySortSelect.addEventListener('change', function() {
        var parts = this.value.split('-');
        densityState.sort = parts[0];
        densityState.order = parts[1];
        densityState.page = 1;
        loadDensity();
    });

    // Pagination
    densityPrev.addEventListener('click', function() {
        if (densityState.page > 1) { densityState.page--; loadDensity(); }
    });
    densityNext.addEventListener('click', function() {
        var maxPage = Math.ceil(densityState.total / densityState.perPage);
        if (densityState.page < maxPage) { densityState.page++; loadDensity(); }
    });

    // Load density on first tab click
    document.querySelectorAll('.mt-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
            if (tab.dataset.tab === 'density' && !densityState.loaded) {
                loadDensity();
            }
        });
    });

    function loadDensity() {
        densityStatus.innerHTML = '<span class="mt-spinner"></span> Loading...';
        densityGrid.innerHTML = '';
        densityPager.style.display = 'none';

        var params = new URLSearchParams();
        if (densityState.tier) params.set('tier', densityState.tier);
        params.set('sort', densityState.sort);
        params.set('order', densityState.order);
        params.set('page', densityState.page);
        params.set('per_page', densityState.perPage);

        fetch(densityUrl + '?' + params.toString())
            .then(function(r) { return r.json(); })
            .then(function(data) {
                densityState.loaded = true;
                if (data.error) {
                    densityStatus.textContent = data.error;
                    return;
                }

                // Update summary stats
                var dist = data.distribution || {};
                var sparse = dist.sparse || 0;
                var medium = dist.medium || 0;
                var dense = dist.dense || 0;
                var total = sparse + medium + dense;
                document.getElementById('mt-stat-total').textContent = total;
                document.getElementById('mt-stat-sparse').textContent = sparse;
                document.getElementById('mt-stat-medium').textContent = medium;
                document.getElementById('mt-stat-dense').textContent = dense;

                densityState.total = data.total || 0;

                // Render grid
                var items = data.items || [];
                densityStatus.textContent = densityState.total + ' items' +
                    (densityState.tier ? ' (' + densityState.tier + ')' : '');

                items.forEach(function(item) {
                    var card = document.createElement('div');
                    card.className = 'mt-density-card';
                    card.dataset.id = item.omeka_id;

                    var overrideMark = item.override ? '<span class="mt-override-badge">override</span>' : '';

                    var sourceBadge = item.source && item.source !== 'opencv'
                        ? '<span class="mt-source-badge">' + escHtml(item.source) + '</span>'
                        : '';
                    var metaLine = item.motif_count || item.transcription_length
                        ? '<span class="mt-metric">' + item.motif_count + ' motifs &middot; ' + item.transcription_length + ' chars &middot; score: ' + item.density_score.toFixed(1) + '</span>'
                        : '';
                    var cvLine = item.edge_density
                        ? '<span class="mt-metric mt-metric-secondary">edge: ' + item.edge_density + ' &middot; white: ' + (item.white_pct * 100).toFixed(1) + '%</span>'
                        : '';

                    var imgHtml = item.thumb_url
                        ? '<img src="' + escHtml(item.thumb_url) + '" loading="lazy" alt="Item ' + item.omeka_id + '">'
                        : '<div class="mt-no-image">No image</div>';
                    card.innerHTML =
                        '<div class="mt-card-img-wrap">' +
                            imgHtml +
                            '<span class="mt-tier-badge ' + escHtml(item.tier) + '">' + escHtml(item.tier) + '</span>' +
                            sourceBadge +
                            overrideMark +
                        '</div>' +
                        '<div class="mt-density-info">' +
                            metaLine +
                            cvLine +
                            '<select class="mt-tier-override" data-id="' + item.omeka_id + '">' +
                                '<option value="sparse"' + (item.tier === 'sparse' ? ' selected' : '') + '>Sparse</option>' +
                                '<option value="medium"' + (item.tier === 'medium' ? ' selected' : '') + '>Medium</option>' +
                                '<option value="dense"' + (item.tier === 'dense' ? ' selected' : '') + '>Dense</option>' +
                            '</select>' +
                        '</div>';

                    // Click image to open admin edit
                    card.querySelector('.mt-card-img-wrap').addEventListener('click', function() {
                        window.open('/admin/item/' + item.omeka_id + '/edit', '_blank');
                    });

                    // Override select
                    card.querySelector('.mt-tier-override').addEventListener('change', function() {
                        var sel = this;
                        var newTier = sel.value;
                        var id = sel.dataset.id;
                        var url = densityOverrideUrlTpl.replace('__ID__', id);

                        sel.disabled = true;
                        fetch(url, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                            body: JSON.stringify({ tier: newTier })
                        })
                        .then(function(r) { return r.json(); })
                        .then(function(data) {
                            sel.disabled = false;
                            if (data.error) {
                                alert('Override failed: ' + data.error);
                                return;
                            }
                            // Update badge
                            var badge = card.querySelector('.mt-tier-badge');
                            badge.className = 'mt-tier-badge ' + newTier;
                            badge.textContent = newTier;
                            // Add override badge if not present
                            if (!card.querySelector('.mt-override-badge')) {
                                var ob = document.createElement('span');
                                ob.className = 'mt-override-badge';
                                ob.textContent = 'override';
                                card.querySelector('.mt-card-img-wrap').appendChild(ob);
                            }
                        })
                        .catch(function(e) {
                            sel.disabled = false;
                            alert('Override failed: ' + e.message);
                        });
                    });

                    densityGrid.appendChild(card);
                });

                // Pagination
                var maxPage = Math.ceil(densityState.total / densityState.perPage);
                if (maxPage > 1) {
                    densityPager.style.display = 'flex';
                    densityPrev.disabled = densityState.page <= 1;
                    densityNext.disabled = densityState.page >= maxPage;
                    densityPageInfo.textContent = 'Page ' + densityState.page + ' of ' + maxPage;
                } else {
                    densityPager.style.display = 'none';
                }
            })
            .catch(function(e) {
                densityStatus.textContent = 'Failed to load density data: ' + e.message;
            });
    }

    // --- Helpers ---
    function escHtml(str) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
    }
})();
</script>
