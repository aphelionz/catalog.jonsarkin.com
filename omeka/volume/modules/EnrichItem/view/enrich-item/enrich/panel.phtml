<?php
/**
 * Enrichment panel injected into admin item show pages.
 * @var int $itemId
 * @var \Omeka\Api\Representation\ItemRepresentation $item
 */
$analyzeUrl = $this->url('admin/enrich-item', ['item_id' => $itemId]);
$applyUrl = $this->url('admin/enrich-item/apply', ['item_id' => $itemId]);
$ingestUrl = $this->url('admin/enrich-item/ingest', ['item_id' => $itemId]);
$media = $item->media();
$primaryMedia = count($media) ? $media[0] : null;
$largeUrl = $primaryMedia ? $primaryMedia->thumbnailUrl('large') : null;
$originalUrl = $primaryMedia ? $primaryMedia->originalUrl() : null;
?>

<div id="enrich" class="section">
    <h3>Enrich with Claude</h3>

    <?php if ($largeUrl): ?>
    <div style="margin-bottom: 1em;">
        <a href="<?= $this->escapeHtmlAttr($originalUrl) ?>" target="_blank">
            <img src="<?= $this->escapeHtmlAttr($largeUrl) ?>"
                 alt="<?= $this->escapeHtml($item->displayTitle()) ?>"
                 style="max-width: 100%; max-height: 500px; border: 1px solid #ddd;">
        </a>
    </div>
    <?php endif; ?>

    <div id="enrich-controls">
        <button type="button" id="enrich-analyze-btn" class="button">Analyze with Claude</button>
        <span id="enrich-status" style="margin-left: 1em; color: #666;"></span>
    </div>

    <div id="enrich-results" style="display: none; margin-top: 1em;">
        <table class="tablesaw" style="width: 100%;">
            <thead>
                <tr>
                    <th style="width: 30px;"></th>
                    <th>Field</th>
                    <th>Current</th>
                    <th>Suggested</th>
                </tr>
            </thead>
            <tbody id="enrich-diff-body"></tbody>
        </table>

        <div style="margin-top: 1em;">
            <button type="button" id="enrich-apply-btn" class="button">Apply Selected</button>
            <button type="button" id="enrich-apply-ingest-btn" class="button" style="margin-left: 0.5em;">Apply & Re-index</button>
            <span id="enrich-apply-status" style="margin-left: 1em; color: #666;"></span>
        </div>
    </div>
</div>

<script>
(function() {
    var analyzeUrl = <?= json_encode($analyzeUrl) ?>;
    var applyUrl = <?= json_encode($applyUrl) ?>;
    var ingestUrl = <?= json_encode($ingestUrl) ?>;
    var enrichment = null;
    var diff = null;

    var analyzeBtn = document.getElementById('enrich-analyze-btn');
    var status = document.getElementById('enrich-status');
    var results = document.getElementById('enrich-results');
    var diffBody = document.getElementById('enrich-diff-body');
    var applyBtn = document.getElementById('enrich-apply-btn');
    var applyIngestBtn = document.getElementById('enrich-apply-ingest-btn');
    var applyStatus = document.getElementById('enrich-apply-status');

    analyzeBtn.addEventListener('click', function() {
        analyzeBtn.disabled = true;
        status.textContent = 'Analyzing...';

        fetch(analyzeUrl, { method: 'POST', headers: { 'Accept': 'application/json' } })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.error) {
                    status.textContent = 'Error: ' + data.error;
                    analyzeBtn.disabled = false;
                    return;
                }
                enrichment = data.enrichment;
                diff = data.diff;
                renderDiff(diff);
                results.style.display = 'block';
                status.textContent = 'Done.';
                analyzeBtn.disabled = false;
            })
            .catch(function(e) {
                status.textContent = 'Error: ' + e.message;
                analyzeBtn.disabled = false;
            });
    });

    function renderDiff(diff) {
        diffBody.innerHTML = '';
        var fieldLabels = {
            transcription: 'Transcription',
            signature: 'Signature',
            date: 'Date',
            medium: 'Medium',
            support: 'Support',
            work_type: 'Work Type',
            motifs: 'Motifs',
            condition_notes: 'Condition'
        };

        for (var field in diff) {
            var d = diff[field];
            var suggested = d.suggested;
            if (suggested === null || suggested === '' || (Array.isArray(suggested) && suggested.length === 0)) {
                continue;
            }

            var tr = document.createElement('tr');
            var currentText = Array.isArray(d.current) ? d.current.join(', ') : (d.current || '(empty)');
            var suggestedText = Array.isArray(suggested) ? suggested.join(', ') : suggested;

            tr.innerHTML =
                '<td><input type="checkbox" name="enrich_field" value="' + field + '"' +
                (d.empty ? ' checked' : '') + '></td>' +
                '<td><strong>' + (fieldLabels[field] || field) + '</strong></td>' +
                '<td>' + escapeHtml(currentText) + '</td>' +
                '<td>' + escapeHtml(suggestedText) + '</td>';

            if (!d.empty) {
                tr.style.opacity = '0.6';
            }

            diffBody.appendChild(tr);
        }
    }

    function getSelectedFields() {
        var fields = {};
        var checkboxes = diffBody.querySelectorAll('input[name="enrich_field"]:checked');
        checkboxes.forEach(function(cb) {
            var field = cb.value;
            if (enrichment[field] !== undefined) {
                fields[field] = enrichment[field];
            }
        });
        return fields;
    }

    applyBtn.addEventListener('click', function() {
        var fields = getSelectedFields();
        if (Object.keys(fields).length === 0) {
            applyStatus.textContent = 'No fields selected.';
            return;
        }
        applyBtn.disabled = true;
        applyIngestBtn.disabled = true;
        applyStatus.textContent = 'Applying...';

        fetch(applyUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ fields: fields })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                applyStatus.textContent = 'Error: ' + data.error;
            } else {
                applyStatus.textContent = 'Applied! Reload to see changes.';
            }
            applyBtn.disabled = false;
            applyIngestBtn.disabled = false;
        })
        .catch(function(e) {
            applyStatus.textContent = 'Error: ' + e.message;
            applyBtn.disabled = false;
            applyIngestBtn.disabled = false;
        });
    });

    applyIngestBtn.addEventListener('click', function() {
        var fields = getSelectedFields();
        if (Object.keys(fields).length === 0) {
            applyStatus.textContent = 'No fields selected.';
            return;
        }
        applyBtn.disabled = true;
        applyIngestBtn.disabled = true;
        applyStatus.textContent = 'Applying...';

        fetch(applyUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ fields: fields })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                applyStatus.textContent = 'Error: ' + data.error;
                applyBtn.disabled = false;
                applyIngestBtn.disabled = false;
                return;
            }
            applyStatus.textContent = 'Re-indexing search...';
            return fetch(ingestUrl, { method: 'POST', headers: { 'Accept': 'application/json' } });
        })
        .then(function(r) { if (r) return r.json(); })
        .then(function(data) {
            if (data && data.error) {
                applyStatus.textContent = 'Applied but ingest failed: ' + data.error;
            } else {
                applyStatus.textContent = 'Applied & indexed! Reload to see changes.';
            }
            applyBtn.disabled = false;
            applyIngestBtn.disabled = false;
        })
        .catch(function(e) {
            applyStatus.textContent = 'Error: ' + e.message;
            applyBtn.disabled = false;
            applyIngestBtn.disabled = false;
        });
    });

    function escapeHtml(text) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }
})();
</script>
