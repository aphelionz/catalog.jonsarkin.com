<?php
/**
 * Public chronological list of Exhibition items.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var array $exhibitions  Rows from ExhibitionsController::indexAction
 * @var int   $total
 */

$this->headTitle('Exhibitions');

$escape = $this->plugin('escapeHtml');
// Site-child route — site context is available via currentSite().
$siteSlug = $this->currentSite()->slug();
?>

<style>
.exhibitions-page {
    max-width: 960px;
    margin: calc(var(--gutter) * 2) auto calc(var(--gutter) * 4);
    padding: 0 var(--gutter);
}
.exhibitions-page h1 {
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.35rem;
}
.exhibitions-page .page-intro {
    font-size: 0.85rem;
    color: var(--text-secondary, #777);
    margin: 0 0 calc(var(--gutter) * 2);
    line-height: 1.6;
}
.exhibitions-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font);
    font-size: 0.9rem;
}
.exhibitions-table thead th {
    text-align: left;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary, #777);
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--text, #161a2b);
}
.exhibitions-table tbody tr {
    border-bottom: 1px solid var(--border-muted, rgba(0,0,0,0.08));
    transition: background-color 0.15s ease;
}
.exhibitions-table tbody tr.is-clickable { cursor: pointer; }
.exhibitions-table tbody tr.is-clickable:hover {
    background-color: var(--surface-hover, rgba(22, 26, 43, 0.04));
}
.exhibitions-table tbody tr.is-static {
    opacity: 0.72;
}
.exhibitions-table td {
    padding: 0.75rem;
    vertical-align: top;
    line-height: 1.4;
}
.exhibitions-table td a {
    color: inherit;
    text-decoration: none;
    display: block;
}
.exhibitions-table td a:hover { text-decoration: underline; }
.exhibitions-table td.col-date {
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary, #777);
    width: 14ch;
}
.exhibitions-table td.col-title { font-weight: 500; }
.exhibitions-table td.col-venue { color: var(--text-secondary, #777); }
.exhibitions-table td.col-type {
    white-space: nowrap;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-secondary, #777);
    width: 10ch;
}
.exhibitions-table td .piece-badge {
    display: inline-block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-secondary, #777);
    margin-left: 0.5rem;
    font-weight: 400;
}

/* Mobile — collapse table into stacked rows */
@media (max-width: 640px) {
    .exhibitions-table thead { display: none; }
    .exhibitions-table tbody tr {
        display: block;
        padding: 0.85rem 0.25rem;
    }
    .exhibitions-table td {
        display: block;
        padding: 0.1rem 0.25rem;
    }
    .exhibitions-table td.col-date { width: auto; }
    .exhibitions-table td.col-title { font-weight: 600; font-size: 1rem; }
    .exhibitions-table td.col-type { width: auto; }
