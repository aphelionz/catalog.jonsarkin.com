</style>

<div class="exhibitions-page">
    <h1>Exhibitions</h1>
    <p class="page-intro">
        <?= (int) $total ?> documented exhibitions from 1999 to present.
        Entries with linked works are clickable.
    </p>

    <table class="exhibitions-table">
        <thead>
            <tr>
                <th class="col-date">Date</th>
                <th class="col-title">Title</th>
                <th class="col-venue">Venue</th>
                <th class="col-type">Type</th>
            </tr>
        </thead>
        <tbody>
        <?php foreach ($exhibitions as $ex): ?>
            <?php
                $isClickable = ((int) $ex['linked_count']) > 0;
                $title = $ex['title'] ?? '—';
                $date = $ex['date'] ?? '';
                $venue = $ex['venue'] ?? '';
                $type = $ex['type'] ?? '';
                // Rendered URL will be cleaned to /item/{id} by clean-urls.php output filter.
                $itemUrl = sprintf('/s/%s/item/%d', $siteSlug, (int) $ex['id']);
                $rowClass = $isClickable ? 'is-clickable' : 'is-static';
            ?>
            <tr class="<?= $escape($rowClass) ?>"
                <?php if ($isClickable): ?>
                    data-href="<?= $escape($itemUrl) ?>"
                    onclick="window.location='<?= $escape($itemUrl) ?>'"
                <?php endif; ?>
            >
                <td class="col-date"><?= $escape($date) ?></td>
                <td class="col-title">
                    <?php if ($isClickable): ?>
                        <a href="<?= $escape($itemUrl) ?>"><?= $escape($title) ?></a>
                    <?php else: ?>
                        <?= $escape($title) ?>
                    <?php endif; ?>
                    <?php if ($isClickable): ?>
                        <span class="piece-badge"><?= (int) $ex['linked_count'] ?> pieces</span>
                    <?php endif; ?>
                </td>
                <td class="col-venue"><?= $escape($venue) ?></td>
                <td class="col-type"><?= $escape($type) ?></td>
            </tr>
        <?php endforeach; ?>
        </tbody>
    </table>
</div>
