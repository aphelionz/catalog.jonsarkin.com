<style>
#simple-upload-dropzone {
    border: 2px dashed #adb5bd;
    border-radius: 6px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background-color 0.2s;
    margin: 1rem 0;
}
#simple-upload-dropzone.drag-over {
    border-color: #495057;
    background: #f1f3f5;
}
#simple-upload-dropzone.uploading {
    opacity: 0.6;
    pointer-events: none;
}
.dropzone-file-input {
    display: block;
    margin: 1rem auto 0;
}
#simple-upload-file-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    text-align: left;
}
#simple-upload-file-list li {
    padding: 0.25rem 0;
    border-bottom: 1px solid #dee2e6;
    display: flex;
    justify-content: space-between;
}
#simple-upload-file-list .file-size {
    color: #868e96;
    font-size: 0.875em;
}
#simple-upload-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var UPLOAD_URL = <?= json_encode($uploadUrl) ?>;
    var dropzone = document.getElementById('simple-upload-dropzone');
    var input = document.getElementById('simple-upload-input');
    var fileList = document.getElementById('simple-upload-file-list');
    var submitBtn = document.getElementById('simple-upload-submit');
    var form = document.getElementById('simple-upload-form');
    var resultsDiv = document.getElementById('upload-results');
    var resultsBody = document.getElementById('results-body');
    var progressDiv = document.getElementById('upload-progress');
    var progressText = document.getElementById('progress-text');
    var progressBar = document.getElementById('progress-bar');

    function formatSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
    }

    function escapeHtml(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    function updateFileList() {
        fileList.innerHTML = '';
        var files = input.files;
        submitBtn.disabled = (files.length === 0);
        for (var i = 0; i < files.length; i++) {
            var li = document.createElement('li');
            var nameSpan = document.createElement('span');
            nameSpan.textContent = files[i].name;
            var sizeSpan = document.createElement('span');
            sizeSpan.className = 'file-size';
            sizeSpan.textContent = formatSize(files[i].size);
            li.appendChild(nameSpan);
            li.appendChild(sizeSpan);
            fileList.appendChild(li);
        }
    }

    function addResultRow(filename, success, itemId, itemUrl, error) {
        var tr = document.createElement('tr');
        var statusHtml;
        var itemHtml;
        if (success) {
            statusHtml = '<span class="o-icon-public" aria-label="Success" title="Success"></span> Created';
            itemHtml = '<a href="' + escapeHtml(itemUrl) + '">#' + itemId + '</a>';
        } else {
            statusHtml = '<span class="o-icon-private" aria-label="Error" title="Error"></span> ' + escapeHtml(error);
            itemHtml = '&mdash;';
        }
        tr.innerHTML = '<td>' + escapeHtml(filename) + '</td><td>' + statusHtml + '</td><td>' + itemHtml + '</td>';
        resultsBody.appendChild(tr);
    }

    async function uploadFiles(files) {
        var total = files.length;
        var succeeded = 0;
        var failed = 0;

        // Reset UI
        resultsBody.innerHTML = '';
        resultsDiv.style.display = '';
        progressDiv.style.display = '';
        dropzone.classList.add('uploading');
        submitBtn.textContent = 'Uploading\u2026';
        submitBtn.disabled = true;

        for (var i = 0; i < total; i++) {
            var file = files[i];
            var current = i + 1;
            progressText.textContent = 'Uploading ' + current + ' of ' + total + ': ' + file.name;
            progressBar.style.width = ((current - 1) / total * 100) + '%';

            var formData = new FormData();
            formData.append('file[]', file);

            try {
                var response = await fetch(UPLOAD_URL, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Server returned ' + response.status);
                }

                var result = await response.json();
                if (result.success) {
                    succeeded++;
                    addResultRow(file.name, true, result.item_id, result.url, null);
                } else {
                    failed++;
                    addResultRow(file.name, false, null, null, result.error || 'Unknown error');
                }
            } catch (err) {
                failed++;
                addResultRow(file.name, false, null, null, err.message || 'Network error');
            }

            progressBar.style.width = (current / total * 100) + '%';
        }

        progressText.textContent = 'Done! ' + succeeded + ' created' + (failed > 0 ? ', ' + failed + ' failed' : '') + '.';
        dropzone.classList.remove('uploading');
        submitBtn.textContent = 'Upload and Create Items';
        // Clear the file input so they can upload more
        input.value = '';
        fileList.innerHTML = '';
        submitBtn.disabled = true;
    }

    // Drag and drop
    dropzone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropzone.classList.add('drag-over');
    });
    dropzone.addEventListener('dragleave', function() {
        dropzone.classList.remove('drag-over');
    });
    dropzone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropzone.classList.remove('drag-over');
        input.files = e.dataTransfer.files;
        updateFileList();
    });
    dropzone.addEventListener('click', function(e) {
        if (e.target !== input) {
            input.click();
        }
    });

    input.addEventListener('change', updateFileList);

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (input.files.length === 0) return;
        uploadFiles(Array.from(input.files));
    });
});
</script>
