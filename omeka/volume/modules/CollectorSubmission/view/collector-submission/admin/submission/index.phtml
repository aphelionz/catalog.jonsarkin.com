<?php
/**
 * Admin: list all collector submissions.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var array $submissions
 * @var array $statusCounts
 * @var string|null $currentStatus
 */

$this->htmlElement('body')->appendAttribute('class', 'collector-submissions browse');
$this->headTitle('Collector Submissions');
?>

<?= $this->pageTitle('Collector Submissions') ?>

<style>
.cs-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
}
.cs-filters a {
    padding: 0.3rem 0.75rem;
    font-size: 0.8rem;
    text-decoration: none;
    border: 1px solid #ccc;
    color: #333;
}
.cs-filters a.active {
    background: #333;
    color: #fff;
    border-color: #333;
}
.cs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
}
.cs-table th {
    text-align: left;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem;
    border-bottom: 2px solid #333;
    color: #777;
}
.cs-table td {
    padding: 0.5rem;
    border-bottom: 1px solid #ddd;
    vertical-align: top;
}
.cs-table tr:hover td {
    background: #f5f5f5;
}
.cs-status {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
    border: 1px solid;
}
.cs-status--new { color: #2563eb; border-color: #93c5fd; background: #eff6ff; }
.cs-status--reviewed { color: #7c3aed; border-color: #c4b5fd; background: #f5f3ff; }
.cs-status--accepted { color: #16a34a; border-color: #86efac; background: #f0fdf4; }
.cs-status--rejected { color: #dc2626; border-color: #fca5a5; background: #fef2f2; }
.cs-empty {
    text-align: center;
    padding: 3rem;
    color: #777;
    font-size: 0.9rem;
}
</style>

<div class="cs-filters">
    <a href="<?= $this->url('admin/collector-submissions') ?>"
       class="<?= $currentStatus === null ? 'active' : '' ?>">
        All (<?= $statusCounts['all'] ?? 0 ?>)
    </a>
    <?php foreach (['new', 'reviewed', 'accepted', 'rejected'] as $st): ?>
        <a href="<?= $this->url('admin/collector-submissions', [], ['query' => ['status' => $st]]) ?>"
           class="<?= $currentStatus === $st ? 'active' : '' ?>">
            <?= ucfirst($st) ?> (<?= $statusCounts[$st] ?? 0 ?>)
        </a>
    <?php endforeach ?>
</div>

<?php if (empty($submissions)): ?>
    <div class="cs-empty">No submissions found.</div>
<?php else: ?>
    <table class="cs-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Collector</th>
                <th>Email</th>
                <th>Pieces</th>
                <th>How Acquired</th>
                <th>Photos</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($submissions as $s): ?>
                <tr>
                    <td>
                        <a href="<?= $this->url('admin/collector-submissions/show', ['id' => $s['id']]) ?>">
                            <?= $s['id'] ?>
                        </a>
                    </td>
                    <td>
                        <a href="<?= $this->url('admin/collector-submissions/show', ['id' => $s['id']]) ?>">
                            <?= $this->escapeHtml($s['collector_name']) ?>
                        </a>
                    </td>
                    <td><?= $this->escapeHtml($s['email']) ?></td>
                    <td><?= (int) $s['num_pieces'] ?></td>
                    <td><?= $this->escapeHtml($s['how_acquired']) ?></td>
                    <td><?= count($s['files']) ?></td>
                    <td><span class="cs-status cs-status--<?= $this->escapeHtmlAttr($s['status']) ?>"><?= $this->escapeHtml($s['status']) ?></span></td>
                    <td><?= $this->escapeHtml(substr($s['created'], 0, 10)) ?></td>
                </tr>
            <?php endforeach ?>
        </tbody>
    </table>
<?php endif ?>
