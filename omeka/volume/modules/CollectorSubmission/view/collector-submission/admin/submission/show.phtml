<script>
(function() {
    var statusSelect = document.getElementById('status');
    var reasonGroup = document.getElementById('rejection-reason-group');
    function toggle() {
        reasonGroup.style.display = statusSelect.value === 'rejected' ? '' : 'none';
    }
    statusSelect.addEventListener('change', toggle);
    toggle();
})();

(function() {
    var rotateUrl = <?= json_encode($this->url('admin/collector-submissions/rotate-image', ['id' => $s['id']])) ?>;
    var csrfToken = <?= json_encode($csrfToken) ?>;
    document.querySelectorAll('.cs-rot').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var card = btn.closest('.cs-photo');
            var idx = card.dataset.idx;
            var deg = btn.dataset.deg;
            var buttons = card.querySelectorAll('button');
            buttons.forEach(function(b) { b.disabled = true; });

            var body = 'index=' + encodeURIComponent(idx) +
                       '&degrees=' + encodeURIComponent(deg) +
                       '&csrf=' + encodeURIComponent(csrfToken);

            fetch(rotateUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json'
                },
                body: body,
                credentials: 'same-origin'
            })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                if (res && res.ok) {
                    var img = card.querySelector('img');
                    if (img) {
                        img.src = img.dataset.base + '?v=' + Date.now();
                    }
                } else {
                    alert('Rotation failed: ' + (res && res.error ? res.error : 'unknown error'));
                }
            })
            .catch(function(e) { alert('Rotation failed: ' + e.message); })
            .finally(function() {
                buttons.forEach(function(b) { b.disabled = false; });
            });
        });
    });
})();
</script>
