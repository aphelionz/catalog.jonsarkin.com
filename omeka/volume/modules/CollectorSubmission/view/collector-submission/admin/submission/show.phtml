<script>
(function() {
    var statusSelect = document.getElementById('status');
    var reasonGroup = document.getElementById('rejection-reason-group');
    function toggle() {
        reasonGroup.style.display = statusSelect.value === 'rejected' ? '' : 'none';
    }
    statusSelect.addEventListener('change', toggle);
    toggle();
})();
</script>
