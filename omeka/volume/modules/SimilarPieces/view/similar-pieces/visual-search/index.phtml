<?php
$heading = 'Visual Search';
$this->headTitle($heading);
$siteSlug = $siteSlug ?? 'catalog';
$jsonUrl = $this->url('site/visual-search/json', [], true);
$siteItemUrl = function ($id) use ($siteSlug) {
    if ($siteSlug === '') {
        return null;
    }
    try {
        return $this->url('site/resource-id', [
            'site-slug' => $siteSlug,
            'controller' => 'item',
            'id' => $id,
        ]);
    } catch (\Throwable $e) {
        return null;
    }
};
