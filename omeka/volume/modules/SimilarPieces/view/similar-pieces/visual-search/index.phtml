<?php if ($searched && empty($error) && empty($results)): ?>
    <p>No matching items found. Try a different image.</p>
<?php endif; ?>

<?php if (!empty($results)): ?>
    <h2>Results</h2>
    <ul class="resource-list vs-results-grid">
        <?php foreach ($results as $result): ?>
            <?php
            $item = $result['item'];
            $id = $result['id'];
            $label = sprintf('Item #%d', $id);
            $linkUrl = null;
            $thumbUrl = $result['thumb_url'] ?? null;
            $score = $result['score'] ?? null;

            if ($item) {
                $label = $item->displayTitle() ?: $label;
                if ($siteSlug !== '') {
                    $linkUrl = $item->siteUrl($siteSlug);
                }
                $pm = $item->primaryMedia();
                if ($pm) {
                    $thumbUrl = $pm->thumbnailUrl('medium');
                }
            }
            if (!$linkUrl && $siteSlug !== '') {
                $linkUrl = $siteItemUrl($id);
            }
            ?>
            <li class="item resource">
                <?php if ($linkUrl): ?>
                    <a href="<?= $this->escapeHtmlAttr($linkUrl) ?>" class="resource-link">
                        <?php if ($thumbUrl): ?>
                            <img src="<?= $this->escapeHtmlAttr($thumbUrl) ?>" alt="<?= $this->escapeHtmlAttr($label) ?>" loading="lazy">
                        <?php endif; ?>
                        <span class="resource-name"><?= $this->escapeHtml($label) ?></span>
                        <?php if ($score !== null): ?>
                            <span class="resource-score"><?= round($score * 100) ?>% match</span>
                        <?php endif; ?>
                    </a>
                <?php else: ?>
                    <span class="resource-name"><?= $this->escapeHtml($label) ?></span>
                <?php endif; ?>
            </li>
        <?php endforeach; ?>
    </ul>
<?php endif; ?>

<div id="vs-dropzone" class="vs-dropzone">
