<?php
$heading = sprintf('Similar pieces for item #%d', $itemId);
$this->headTitle($heading);
?>

<h1><?= $this->escapeHtml($heading) ?></h1>

<style>
.similar-pieces-source {
    margin-top: 1.25rem;
    padding: 1rem;
    border: 1px solid #e6e6e6;
    border-radius: 16px;
    background: #fff;
