.similar-pieces-source .source-media img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
}
.similar-pieces-source .source-body {
    flex: 1 1 240px;
}
.similar-pieces-source .source-kicker {
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: #666;
    margin-bottom: 0.4rem;
}
.similar-pieces-source .source-title {
    font-size: 1.5rem;
    margin: 0.2rem 0 0.8rem;
}
.similar-pieces-source .source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 600;
}
.similar-pieces-grid {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
