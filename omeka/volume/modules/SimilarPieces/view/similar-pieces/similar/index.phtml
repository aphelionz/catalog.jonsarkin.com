<?php if (!empty($healthWarning)): ?>
    <p class="similar-pieces-warning"><?= $this->escapeHtml($healthWarning) ?></p>
<?php endif; ?>

<?php if ($error): ?>
    <p class="similar-pieces-error"><?= $this->escapeHtml($error) ?></p>
<?php endif; ?>

<?php if (!$error): ?>
    <?php
    $sourceData = $source ?? null;
    $sourceItem = $sourceData['item'] ?? null;
    $sourceId = $sourceData['id'] ?? $itemId;
    $sourceLabel = $sourceData['title'] ?? sprintf('Item #%d', $sourceId);
    $sourceLink = null;
    $sourceThumb = $sourceData['thumb_url'] ?? null;
    $siteItemUrl = function ($id) use ($siteSlug) {
        if ($siteSlug === '') {
            return null;
        }
        try {
            return $this->url('site/resource-id', [
                'site-slug' => $siteSlug,
                'controller' => 'item',
                'id' => $id,
            ]);
        } catch (\Throwable $e) {
            return null;
        }
    };
    if ($sourceItem) {
        $sourceLabel = $sourceItem->displayTitle() ?: $sourceLabel;
        if ($siteSlug !== '') {
            $sourceLink = $sourceItem->siteUrl($siteSlug);
        }
    }
    if (!$sourceLink && !empty($sourceData['url'])) {
        $sourceLink = $sourceData['url'];
    }
    if (!$sourceLink && $siteSlug !== '') {
        $sourceLink = $siteItemUrl($sourceId);
    }
    ?>

    <section class="similar-pieces-source">
        <div class="source-media">
            <?php if ($sourceItem): ?>
                <?= $this->thumbnail($sourceItem, 'large') ?>
            <?php elseif ($sourceThumb): ?>
                <img src="<?= $this->escapeHtmlAttr($sourceThumb) ?>" alt="<?= $this->escapeHtmlAttr($sourceLabel) ?>" loading="lazy">
            <?php endif; ?>
        </div>
        <div class="source-body">
            <div class="source-kicker">Selected Piece</div>
            <h2 class="source-title"><?= $this->escapeHtml($sourceLabel) ?></h2>
            <?php if ($sourceLink): ?>
                <a class="source-link" href="<?= $this->escapeHtmlAttr($sourceLink) ?>">View this item</a>
            <?php else: ?>
                <span class="source-link">View this item</span>
            <?php endif; ?>
        </div>
    </section>
<?php endif; ?>

<?php if (!$error && !$results): ?>
    <p>No similar items found.</p>
<?php endif; ?>

<?php if ($results): ?>
    <ul class="resource-list similar-pieces-grid">
        <?php foreach ($results as $result): ?>
            <?php
            $item = $result['item'];
            $id = $result['id'];
            $label = $result['title'] ?: sprintf('Item #%d', $id);
            $linkUrl = null;
            $thumbUrl = $result['thumb_url'] ?? null;

            if ($item) {
                $label = $item->displayTitle() ?: $label;
                if ($siteSlug !== '') {
                    $linkUrl = $item->siteUrl($siteSlug);
                }
            }
            if (!$linkUrl && !empty($result['url'])) {
                $linkUrl = $result['url'];
            }
            if (!$linkUrl && $siteSlug !== '') {
                $linkUrl = $siteItemUrl($id);
            }
            ?>
            <li class="item resource">
                <?php if ($linkUrl): ?>
                    <a href="<?= $this->escapeHtmlAttr($linkUrl) ?>" class="resource-link">
                        <?php if ($item): ?>
                            <?= $this->thumbnail($item, 'square') ?>
                        <?php elseif ($thumbUrl): ?>
                            <img src="<?= $this->escapeHtmlAttr($thumbUrl) ?>" alt="<?= $this->escapeHtmlAttr($label) ?>" class="resource-thumbnail" loading="lazy">
                        <?php endif; ?>
                        <span class="resource-name"><?= $this->escapeHtml($label) ?></span>
                    </a>
                <?php else: ?>
                    <span class="resource-name"><?= $this->escapeHtml($label) ?></span>
                <?php endif; ?>
            </li>
        <?php endforeach; ?>
    </ul>
<?php endif; ?>
