<?php
/**
 * SiteLockdown — Promotional landing page
 *
 * Standalone page (no Omeka layout) shown to unauthenticated visitors.
 * Displays introductory text, a preview grid of catalog items, and a
 * downplayed password form at the bottom.
 *
 * @var bool  $error        Whether to show a wrong-password message
 * @var array $previewItems Array of Omeka\Api\Representation\ItemRepresentation
 */

$escape = function ($v) { return htmlspecialchars((string) $v, ENT_QUOTES, 'UTF-8'); };

// Helper: extract a single metadata value from an item
$val = function ($item, $term, $fallback = '') use ($escape) {
    $v = $item->value($term, ['default' => null]);
    return $v ? $escape((string) $v) : $fallback;
};

// Reject EXIF timestamps and MIME types
$isArtworkDate = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '') return false;
    if (preg_match('/^\d{4}:\d{2}:\d{2}/', $str)) return false;
    if (preg_match('/\d{4}-\d{2}-\d{2}T/', $str)) return false;
    return true;
};
$isNotMime = function ($str) {
    $str = trim(strip_tags($str));
    if ($str === '') return false;
    if (preg_match('#^[\w-]+/[\w.+-]+$#', $str)) return false;
    return true;
};
?>
