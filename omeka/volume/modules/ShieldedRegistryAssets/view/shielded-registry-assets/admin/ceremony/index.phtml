<script>
(function() {
    var checkBtn = document.getElementById('checkDnsBtn');
    var statusEl = document.getElementById('dnsStatus');
    if (!checkBtn || !statusEl) return;

    checkBtn.addEventListener('click', function() {
        statusEl.innerHTML = '<span class="sra-dns-status sra-dns-status--checking">Checking...</span>';
        checkBtn.disabled = true;

        var formData = new FormData();
        formData.append('domain', <?= json_encode($domain) ?>);
        formData.append('pk_r', <?= json_encode($pkR) ?>);

        fetch(<?= json_encode($this->url('admin/shielded-registry/check-dns')) ?>, {
            method: 'POST',
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var cssClass = 'sra-dns-status--';
            if (data.status === 'verified') cssClass += 'verified';
            else if (data.status === 'mismatch') cssClass += 'mismatch';
            else cssClass += 'failed';

            var html = '<span class="sra-dns-status ' + cssClass + '">' + data.message + '</span>';
            if (data.found && data.found.length) {
                html += '<div style="margin-top:0.5rem;font-size:0.85em;"><strong>Found records:</strong><ul>';
                data.found.forEach(function(v) {
                    html += '<li><code>' + v + '</code></li>';
                });
                html += '</ul></div>';
            }
            statusEl.innerHTML = html;

            if (data.status === 'verified') {
                // Reload to update state
                setTimeout(function() { window.location.reload(); }, 1500);
            }
        })
        .catch(function(err) {
            statusEl.innerHTML = '<span class="sra-dns-status sra-dns-status--failed">Error: ' + err.message + '</span>';
        })
        .finally(function() {
            checkBtn.disabled = false;
        });
    });
})();
</script>
<?php endif; ?>

