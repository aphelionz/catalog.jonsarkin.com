<script src="https://cdn.jsdelivr.net/npm/tweetnacl@1.0.3/nacl-fast.min.js"></script>
<script>
(function() {
    var btn = document.getElementById('devGenerate');
    if (!btn) return;

    btn.addEventListener('click', function() {
        var kp = nacl.sign.keyPair();

        // Convert to hex
        function toHex(uint8) {
            return Array.from(uint8).map(function(b) {
                return b.toString(16).padStart(2, '0');
            }).join('');
        }

        var secretHex = toHex(kp.secretKey.slice(0, 32)); // seed portion
        var publicHex = toHex(kp.publicKey);

        // Auto-fill PK_R field
        var pkField = document.querySelector('input[name="pk_r"]');
        if (pkField) pkField.value = publicHex;

        // Show output
        document.getElementById('devSecretKey').textContent = secretHex;
        document.getElementById('devPublicKey').textContent = publicHex;
        document.getElementById('devKeyOutput').style.display = 'block';
    });
})();
</script>
