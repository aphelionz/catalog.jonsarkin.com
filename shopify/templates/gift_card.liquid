<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | format_address, shop: shop.name }}</title>
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@400;600&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    body { font-family: 'Jost', sans-serif; background: #111; color: #e8e8e8; text-align: center; padding: 3rem 1rem; }
    .gift-card { max-width: 400px; margin: 0 auto; }
    .gift-card__code { font-size: 1.5rem; font-weight: 600; letter-spacing: 0.1em; margin: 2rem 0; padding: 1rem; border: 1px solid #2a2a2a; }
    .gift-card__balance { font-size: 2rem; font-weight: 600; margin-bottom: 1rem; }
    a { color: #e8e8e8; }
  </style>
</head>
<body>
  <div class="gift-card">
    <h1>{{ shop.name }}</h1>
    <div class="gift-card__balance">{{ gift_card.balance | money }}</div>
    <div class="gift-card__code">{{ gift_card.code | format_code }}</div>
    {%- if gift_card.pass_url -%}
      <a href="{{ gift_card.pass_url }}">Add to Apple Wallet</a>
    {%- endif -%}
  </div>
</body>
</html>
