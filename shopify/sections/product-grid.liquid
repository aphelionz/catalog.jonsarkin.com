{%- if collection.handle == 'all' -%}
  <meta http-equiv="refresh" content="0;url=https://catalog.jonsarkin.com/faceted-browse/2?property%5B0%5D%5Bjoiner%5D=and&property%5B0%5D%5Bproperty%5D=388&property%5B0%5D%5Btype%5D=ex">
  <script>window.location.replace('https://catalog.jonsarkin.com/faceted-browse/2?property%5B0%5D%5Bjoiner%5D=and&property%5B0%5D%5Bproperty%5D=388&property%5B0%5D%5Btype%5D=ex');</script>
{%- endif -%}
{%- paginate collection.products by section.settings.products_per_page -%}
<section class="section">
  <div class="page-width">
    {%- assign display_title = collection.title -%}
    <div class="collection-header text-center">
      <h1>{{ display_title }}</h1>
      {%- if collection.description != blank -%}
        <p>{{ collection.description }}</p>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" class="product-card">
          <div class="product-card__image{% if product.metafields.artwork.original_image_url %} product-card__image--hdr{% endif %}">
            {%- if product.metafields.artwork.original_image_url -%}
              <img
                class="product-card__img product-card__img--hdr"
                src="{{ product.metafields.artwork.original_image_url | replace: '/files/original/', '/files/medium/' | replace: '.jpeg', '.jpg' | replace: '.png', '.jpg' }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
              >
            {%- endif -%}
            {%- if product.featured_image -%}
              <img
                class="product-card__img product-card__img--shopify"
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
              >
            {%- endif -%}
          </div>
          <div class="product-card__info">
            <div class="product-card__title">{{ product.title }}</div>
            {%- if product.metafields.artwork.medium -%}
              <div class="product-card__meta">{{ product.metafields.artwork.medium }}{% if product.metafields.artwork.support %} on {{ product.metafields.artwork.support | downcase }}{% endif %}</div>
            {%- endif -%}
            {%- if product.metafields.artwork.dimensions -%}
              <div class="product-card__meta">{{ product.metafields.artwork.dimensions }}</div>
            {%- endif -%}
            <div class="product-card__price">
              {%- if product.available -%}
                {{ product.price | money }}
              {%- else -%}
                <span class="product-card__badge">Inquire</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- else -%}
        <p>No works found in this collection.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}">←</a>
        {%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <span class="current">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}">→</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}

<script>
(function() {
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.6 });

  document.querySelectorAll('.product-card__image--hdr').forEach(function(el) {
    observer.observe(el);
  });
})();
</script>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 48,
      "step": 6,
      "default": 24,
      "label": "Products per page"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "Enable sorting"
    }
  ]
}
{% endschema %}
