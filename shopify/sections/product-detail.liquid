<section class="section">
  <div class="page-width">
    <div class="product-detail{% if template.suffix == 'wide' %} product-detail--wide{% endif %}">
      <div class="product-detail__media">
        <div class="product-detail__main-image" id="product-main-image">
          {%- if product.metafields.artwork.original_image_url -%}
            <img
              id="product-hero-img"
              src="{{ product.metafields.artwork.original_image_url }}"
              alt="{{ product.title | escape }}"
              loading="eager"
            >
          {%- elsif product.featured_image -%}
            <img
              id="product-hero-img"
              src="{{ product.featured_image | image_url }}"
              alt="{{ product.title | escape }}"
              loading="eager"
            >
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-detail__thumbnails">
            {%- for image in product.images -%}
              <button type="button" class="product-detail__thumb-btn{% if forloop.first %} is-active{% endif %}" data-full-src="{% if forloop.first and product.metafields.artwork.original_image_url %}{{ product.metafields.artwork.original_image_url }}{% else %}{{ image | image_url }}{% endif %}" aria-label="View image {{ forloop.index }} of {{ product.images.size }}">
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
          <script>
            document.querySelectorAll('.product-detail__thumb-btn').forEach(function(btn) {
              btn.addEventListener('click', function() {
                document.getElementById('product-hero-img').src = this.dataset.fullSrc;
                document.querySelectorAll('.product-detail__thumb-btn').forEach(function(b) { b.classList.remove('is-active'); });
                this.classList.add('is-active');
              });
            });
          </script>
        {%- endif -%}
      </div>

      <div class="product-detail__info">
        <h1 class="product-detail__title">{{ product.title }}{% unless product.available %} <span class="product-detail__sold-dot" aria-label="Acquired"></span>{% endunless %}</h1>

        <div class="product-detail__metadata">
          {%- if product.metafields.artwork.medium -%}
            {{ product.metafields.artwork.medium }}{% if product.metafields.artwork.support %} on {{ product.metafields.artwork.support | downcase }}{% endif %}<br>
          {%- endif -%}
          {%- if product.metafields.artwork.dimensions -%}
            {{ product.metafields.artwork.dimensions }}<br>
          {%- endif -%}
          {%- if product.metafields.artwork.year -%}
            {{ product.metafields.artwork.year }}
          {%- endif -%}
        </div>

        <div class="product-detail__provenance">
          {%- if product.metafields.artwork.signed -%}
            <div class="product-detail__provenance-line">Signed: {{ product.metafields.artwork.signed }}</div>
          {%- endif -%}
          {%- if product.metafields.artwork.condition -%}
            <div class="product-detail__provenance-line">Condition: {{ product.metafields.artwork.condition }}</div>
          {%- endif -%}
          <div class="product-detail__provenance-line">Certificate of Authenticity included</div>
          {%- if product.metafields.artwork.support contains 'album sleeve' -%}
            <div class="product-detail__provenance-line">Ships framed with 99% UV conservation glass</div>
          {%- endif -%}
          <div class="product-detail__provenance-line">Right of first refusal retained by the estate.</div>
          {%- if product.metafields.artwork.provenance -%}
            <div class="product-detail__provenance-line">Provenance: {{ product.metafields.artwork.provenance }}</div>
          {%- endif -%}
        </div>

        {%- if product.metafields.artwork.content_excerpt -%}
          <blockquote class="product-detail__excerpt">{{ product.metafields.artwork.content_excerpt }}</blockquote>
        {%- endif -%}

        <div class="product-detail__price">
          {{ product.price | money }}
        </div>

        <div class="product-detail__actions">
          {%- if product.available -%}
            {%- form 'product', product -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" class="btn btn--primary">
                {{ 'products.product.add_to_cart' | t }}
              </button>
            {%- endform -%}
          {%- else -%}
            <button disabled class="btn btn--primary btn--disabled">Acquired</button>
          {%- endif -%}

          {%- if product.metafields.artwork.catalog_url -%}
            <a href="{{ product.metafields.artwork.catalog_url }}" class="product-detail__catalog-link" target="_blank" rel="noopener">
              View in the Catalog Raisonné →
            </a>
          {%- endif -%}
          {%- if product.available -%}
            <a href="/pages/contact" class="product-detail__catalog-link">
              Request a condition report →
            </a>
          {%- endif -%}
        </div>

        {%- if product.description != blank -%}
          {%- unless product.description contains '<!-- agent-only -->' -%}
            <div class="product-detail__description">
              {{ product.description }}
            </div>
          {%- endunless -%}
        {%- endif -%}
      </div>
    </div>

    <div class="why-this-matters">
      <h2 class="section-heading">Why This Work Matters</h2>
      <div class="body-text">
        <p>Jon Sarkin&rsquo;s work is held in the permanent collections of the <strong>Centre Pompidou</strong> (Paris), the <strong>MoMA Archives</strong> (Calvin Tomkins Papers), the <strong>Cape Ann Museum</strong>, the <strong>DeCordova Sculpture Park &amp; Museum</strong>, the <strong>Addison Gallery of American Art</strong> at Phillips Academy, and <strong>Pingry School</strong>.</p>
      </div>

      <div class="scholarly-quote">
        <blockquote>&ldquo;Sarkin&rsquo;s work approaches what Andr&eacute; Breton dreamed of but which most Surrealists never achieved: pure psychic automatism.&rdquo;</blockquote>
        <div class="attribution"><strong>Colin Rhodes</strong> &mdash; Distinguished Professor; Contributing Editor, <em>Raw Vision</em>; in <a href="https://www.cambridge.org/core/journals/epidemiology-and-psychiatric-sciences/article/jon-sarkin-the-eternal-now/DE3106B8C0F78C0557015414358FF42F" target="_blank" rel="noopener"><em>Epidemiology and Psychiatric Sciences</em></a>, Cambridge University Press, 2023.</div>
      </div>

      <p class="press-strip">Featured in: <a href="https://www.wbur.org/news/2025/05/02/gloucester-gallery-opens-to-cement-jon-sarkins-artistic-legacy" target="_blank" rel="noopener"><em>Gloucester gallery opens to cement Jon Sarkin&rsquo;s artistic legacy</em></a> &mdash; Amelia Mason, WBUR, May 2025.</p>
    </div>

    {%- if section.settings.show_related and recommendations.products_count > 0 -%}
      <div class="related-products">
        <h2>Related Works</h2>
        <div class="product-grid">
          {%- for product in recommendations.products limit: 8 -%}
            <a href="{{ product.url }}" class="product-card">
              <div class="product-card__image">
                {%- if product.featured_image -%}
                  {{ product.featured_image | image_url: width: 600 | image_tag: alt: product.title, loading: 'lazy' }}
                {%- endif -%}
                {%- unless product.available -%}
                  <span class="product-card__sold-dot" aria-label="Acquired"></span>
                {%- endunless -%}
              </div>
              <div class="product-card__info">
                <div class="product-card__title">{{ product.title }}</div>
                {%- if product.metafields.artwork.medium -%}
                  <div class="product-card__meta">{{ product.metafields.artwork.medium }}{% if product.metafields.artwork.support %} on {{ product.metafields.artwork.support | downcase }}{% endif %}</div>
                {%- endif -%}
                <div class="product-card__price">
                  {%- if product.available -%}
                    {{ product.price | money }}
                  {%- else -%}
                    <span class="product-card__badge product-card__badge--sold">Acquired</span><span class="product-card__sold-price">{{ product.price | money }}</span>
                  {%- endif -%}
                </div>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product detail",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_related",
      "default": true,
      "label": "Show related works"
    }
  ]
}
{% endschema %}
