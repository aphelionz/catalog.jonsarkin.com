<section class="section">
  <div class="page-width">
    <div class="product-detail">
      <div class="product-detail__media">
        <div class="product-detail__main-image" id="product-main-image">
          {%- if product.metafields.artwork.original_image_url -%}
            <img
              id="product-hero-img"
              src="{{ product.metafields.artwork.original_image_url }}"
              alt="{{ product.title | escape }}"
              loading="eager"
            >
          {%- elsif product.featured_image -%}
            <img
              id="product-hero-img"
              src="{{ product.featured_image | image_url }}"
              alt="{{ product.title | escape }}"
              loading="eager"
            >
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-detail__thumbnails">
            {%- for image in product.images -%}
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                class="product-detail__thumb{% if forloop.first %} is-active{% endif %}"
                data-full-src="{% if forloop.first and product.metafields.artwork.original_image_url %}{{ product.metafields.artwork.original_image_url }}{% else %}{{ image | image_url }}{% endif %}"
                loading="lazy"
              >
            {%- endfor -%}
          </div>
          <script>
            document.querySelectorAll('.product-detail__thumb').forEach(function(thumb) {
              thumb.addEventListener('click', function() {
                document.getElementById('product-hero-img').src = this.dataset.fullSrc;
                document.querySelectorAll('.product-detail__thumb').forEach(function(t) { t.classList.remove('is-active'); });
                this.classList.add('is-active');
              });
            });
          </script>
        {%- endif -%}
      </div>

      <div class="product-detail__info">
        <h1 class="product-detail__title">{{ product.title }}</h1>

        <div class="product-detail__metadata">
          {%- if product.metafields.artwork.medium -%}
            {{ product.metafields.artwork.medium }}{% if product.metafields.artwork.support %} on {{ product.metafields.artwork.support | downcase }}{% endif %}<br>
          {%- endif -%}
          {%- if product.metafields.artwork.dimensions -%}
            {{ product.metafields.artwork.dimensions }}<br>
          {%- endif -%}
          {%- if product.metafields.artwork.year -%}
            {{ product.metafields.artwork.year }}
          {%- endif -%}
        </div>

        <div class="product-detail__provenance">
          {%- if product.metafields.artwork.signed -%}
            <div class="product-detail__provenance-line">Signed: {{ product.metafields.artwork.signed }}</div>
          {%- endif -%}
          {%- if product.metafields.artwork.condition -%}
            <div class="product-detail__provenance-line">Condition: {{ product.metafields.artwork.condition }}</div>
          {%- endif -%}
          <div class="product-detail__provenance-line">Certificate of Authenticity included</div>
          <div class="product-detail__provenance-line">Right of first refusal retained by the estate.</div>
          {%- if product.metafields.artwork.provenance -%}
            <div class="product-detail__provenance-line">Provenance: {{ product.metafields.artwork.provenance }}</div>
          {%- endif -%}
        </div>

        {%- if product.metafields.artwork.content_excerpt -%}
          <blockquote class="product-detail__excerpt">{{ product.metafields.artwork.content_excerpt }}</blockquote>
        {%- endif -%}

        <div class="product-detail__price">
          {{ product.price | money }}
        </div>

        <div class="product-detail__actions">
          {%- if product.available -%}
            {%- if product.price >= 1000000 -%}
              <a href="/pages/contact?subject={{ product.title | url_encode }}" class="btn btn--primary">
                Inquire About This Work
              </a>
            {%- else -%}
              {%- form 'product', product -%}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="btn btn--primary">
                  {{ 'products.product.add_to_cart' | t }}
                </button>
              {%- endform -%}
            {%- endif -%}
          {%- else -%}
            <button disabled class="btn btn--primary btn--disabled">Acquired</button>
          {%- endif -%}

          {%- if product.metafields.artwork.catalog_url -%}
            <a href="{{ product.metafields.artwork.catalog_url }}" class="product-detail__catalog-link" target="_blank" rel="noopener">
              View in the Catalog Raisonné →
            </a>
          {%- endif -%}
          <a href="/pages/contact" class="product-detail__catalog-link">
            Request a condition report →
          </a>
        </div>

        {%- if product.description != blank -%}
          <div class="product-detail__description">
            {{ product.description }}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_related and recommendations.products_count > 0 -%}
      <div class="related-products">
        <h2>Related Works</h2>
        <div class="product-grid">
          {%- for product in recommendations.products limit: 8 -%}
            <a href="{{ product.url }}" class="product-card">
              <div class="product-card__image">
                {%- if product.featured_image -%}
                  {{ product.featured_image | image_url: width: 600 | image_tag: alt: product.title, loading: 'lazy' }}
                {%- endif -%}
              </div>
              <div class="product-card__info">
                <div class="product-card__title">{{ product.title }}</div>
                {%- if product.metafields.artwork.medium -%}
                  <div class="product-card__meta">{{ product.metafields.artwork.medium }}{% if product.metafields.artwork.support %} on {{ product.metafields.artwork.support | downcase }}{% endif %}</div>
                {%- endif -%}
                <div class="product-card__price">
                  {%- if product.available -%}
                    {{ product.price | money }}
                  {%- else -%}
                    <span class="product-card__badge">Inquire</span>
                  {%- endif -%}
                </div>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product detail",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_related",
      "default": true,
      "label": "Show related works"
    }
  ]
}
{% endschema %}
