<section class="section{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width text-center">
    <div class="rich-text">
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div>{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="rich-text__buttons">
          <a href="{{ section.settings.button_link }}" class="btn"{% if section.settings.button_link contains 'http' %} target="_blank" rel="noopener"{% endif %}>
            {{ section.settings.button_label | escape }}
          </a>
          {%- if section.settings.button_label_2 != blank -%}
            <a href="{{ section.settings.button_link_2 }}" class="btn"{% if section.settings.button_link_2 contains 'http' %} target="_blank" rel="noopener"{% endif %}>
              {{ section.settings.button_label_2 | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show top divider",
      "default": false
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Second button label"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Second button link"
    }
  ],
  "presets": [
    {
      "name": "Rich text"
    }
  ]
}
{% endschema %}
