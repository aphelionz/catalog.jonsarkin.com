<header class="site-header">
  <div class="page-width site-header__inner">
    <div class="site-header__logo">
      <a href="{{ routes.root_url }}">
        {%- if settings.logo -%}
          {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {{ settings.logo | image_url: width: 300 | image_tag:
            width: settings.logo_width,
            height: logo_height,
            alt: shop.name,
            preload: true
          }}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
    </div>

    <nav class="site-header__nav">
      <a href="/pages/about">About</a>
      <a href="/collections/all">Available Works</a>
      <a href="https://catalog.jonsarkin.com" target="_blank" rel="noopener">Catalog Raisonné</a>
      <a href="/pages/contact">Contact</a>

      {%- if cart.item_count > 0 -%}
        <a href="{{ routes.cart_url }}" class="site-header__cart">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
          <span class="cart-count">{{ cart.item_count }}</span>
        </a>
      {%- endif -%}
    </nav>

    <button class="nav-toggle" onclick="document.querySelector('.mobile-nav').classList.toggle('is-open'); this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'true' ? 'false' : 'true')" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</header>

<div class="mobile-nav" id="mobile-nav">
  <a href="/pages/about" onclick="document.querySelector('.mobile-nav').classList.remove('is-open')">About</a>
  <a href="/collections/all" onclick="document.querySelector('.mobile-nav').classList.remove('is-open')">Available Works</a>
  <a href="https://catalog.jonsarkin.com" target="_blank" rel="noopener" onclick="document.querySelector('.mobile-nav').classList.remove('is-open')">Catalog Raisonné</a>
  <a href="/pages/contact" onclick="document.querySelector('.mobile-nav').classList.remove('is-open')">Contact</a>
  {%- if cart.item_count > 0 -%}
    <a href="{{ routes.cart_url }}" onclick="document.querySelector('.mobile-nav').classList.remove('is-open')">
      Selections ({{ cart.item_count }})
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation menu"
    }
  ]
}
{% endschema %}
