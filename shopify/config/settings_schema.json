[
  {
    "name": "theme_info",
    "theme_name": "Sarkin Estate",
    "theme_version": "2.0.0",
    "theme_author": "Jon Sarkin Estate",
    "theme_documentation_url": "https://catalog.jonsarkin.com",
    "theme_support_url": "https://jonsarkin.com"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 150
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background",
        "default": "#0e1018"
      },
      {
        "type": "color",
        "id": "color_bg_surface",
        "label": "Surface background",
        "default": "#131520",
        "info": "Cards, inputs, image placeholders"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Primary text",
        "default": "#e8e8e8"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Secondary text",
        "default": "#888888"
      },
      {
        "type": "color",
        "id": "color_link",
        "label": "Link color",
        "default": "#8a9bb5"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#1e2530"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#ffffff",
        "info": "Hover states, active elements"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "jost_n6"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "jost_n4"
      },
      {
        "type": "range",
        "id": "font_body_scale",
        "min": 80,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "Body font size scale",
        "default": 100
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "https://instagram.com/yourhandle"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube",
        "info": "https://youtube.com/@yourhandle"
      }
    ]
  }
]
