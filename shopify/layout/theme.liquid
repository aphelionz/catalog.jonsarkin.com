<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>
    {%- if template.name == 'product' and product.metafields.artwork.medium -%}
      {{ product.metafields.artwork.medium | strip }}{% if product.metafields.artwork.year %}, {{ product.metafields.artwork.year }}{% endif %} — {{ shop.name }} ({{ product.title }})
    {%- else -%}
      {{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}
    {%- endif -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    :root {
      --bg: {{ settings.color_bg }};
      --bg-surface: {{ settings.color_bg_surface }};
      --text: {{ settings.color_text }};
      --text-secondary: {{ settings.color_text_secondary }};
      --link: {{ settings.color_link }};
      --border: {{ settings.color_border }};
      --accent: {{ settings.color_accent }};
      {%- if settings.font_body -%}
        --font: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
      {%- endif -%}
      {%- if settings.font_body_scale != 100 -%}
        font-size: {{ settings.font_body_scale | times: 0.16 }}px;
      {%- endif -%}
    }
    {%- if settings.font_heading -%}
      h1, h2, h3, h4 { font-family: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }}; }
    {%- endif -%}
    {{ settings.font_body | font_face: font_display: 'swap' }}
    {{ settings.font_heading | font_face: font_display: 'swap' }}
  {%- endstyle -%}

  {{ content_for_header }}
</head>
<body>
  <a href="#main" class="visually-hidden">Skip to content</a>

  {% section 'header' %}

  <main id="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}
</body>
</html>
