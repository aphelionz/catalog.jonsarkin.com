<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <script>(function(){var c=document.cookie.match('(?:^|; )sarkin-theme=([^;]*)');var t=(c&&c[1])||localStorage.getItem('sarkin-theme')||((window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches)?'dark':'light');document.documentElement.setAttribute('data-theme',t);document.cookie='sarkin-theme='+t+';domain=.jonsarkin.com;path=/;max-age=31536000;SameSite=Lax';})()</script>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>
    {%- if template.name == 'product' and product.metafields.artwork.medium -%}
      {{ product.metafields.artwork.medium | strip }}{% if product.metafields.artwork.year %}, {{ product.metafields.artwork.year }}{% endif %} — {{ shop.name }} ({{ product.title }})
    {%- else -%}
      {{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}
    {%- endif -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preload" href="{{ 'Jost-VF.woff2' | asset_url }}" as="font" type="font/woff2" crossorigin>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    html:not([data-theme]) {
      --bg: {{ settings.color_bg }};
      --bg-surface: {{ settings.color_bg_surface }};
      --text: {{ settings.color_text }};
      --text-secondary: {{ settings.color_text_secondary }};
      --link: {{ settings.color_link }};
      --border: {{ settings.color_border }};
      --border-color: {{ settings.color_border }};
      --accent: {{ settings.color_accent }};
      {%- if settings.font_body -%}
        --font: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
      {%- endif -%}
      {%- if settings.font_body_scale != 100 -%}
        font-size: {{ settings.font_body_scale | times: 0.16 }}px;
      {%- endif -%}
    }
    h1, h2, h3, h4 { font-family: var(--font); }
  {%- endstyle -%}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "The Jon Sarkin Estate",
        "url": "https://catalog.jonsarkin.com",
        "description": "The official estate of American outsider artist Jon Sarkin (1953–2024), maintaining the catalog raisonné and Fish City Studios in Gloucester, MA.",
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "Estate Manager",
          "name": "Mark Henderson",
          "email": "art@jonsarkin.com",
          "telephone": "+1-978-328-4466"
        },
        "sameAs": [
          "https://www.instagram.com/jonsarkin/",
          "https://www.youtube.com/@jonsarkin",
          "https://www.facebook.com/jonsarkinart/",
          "https://www.threads.net/@jonsarkin"
        ]
      },
      {
        "@type": "Person",
        "name": "Jon Sarkin",
        "birthDate": "1953-04-27",
        "deathDate": "2024-07-19",
        "birthPlace": "Newark, New Jersey",
        "description": "American outsider artist (1953–2024). Self-taught, his compulsive art practice emerged after a stroke in 1989. His work is in the collections of the Centre Pompidou, the American Visionary Art Museum, the Cape Ann Museum, and the MoMA Archives.",
        "sameAs": [
          "https://en.wikipedia.org/wiki/Jon_Sarkin",
          "https://www.wikidata.org/wiki/Q16185574"
        ]
      }
    ]
  }
  </script>

  {{ content_for_header }}
</head>
<body>
  <a href="#main" class="visually-hidden">Skip to content</a>

  {% section 'header' %}

  <main id="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script>
  (function () {
    'use strict';

    // ── Mobile nav toggle ──
    var navToggle = document.querySelector('.nav-toggle');
    var siteNav = document.getElementById('site-nav');
    var mobileNav = document.getElementById('mobile-nav');
    if (navToggle && mobileNav) {
      var mobileCloseBtn = mobileNav.querySelector('.mobile-nav__close');

      function openMobileNav() {
        mobileNav.classList.add('is-open');
        navToggle.setAttribute('aria-expanded', 'true');
        mobileNav.setAttribute('aria-modal', 'true');
        if (mobileCloseBtn) mobileCloseBtn.focus();
      }

      function closeMobileNav() {
        mobileNav.classList.remove('is-open');
        navToggle.setAttribute('aria-expanded', 'false');
        mobileNav.removeAttribute('aria-modal');
        navToggle.focus();
      }

      navToggle.addEventListener('click', function () {
        if (mobileNav.classList.contains('is-open')) {
          closeMobileNav();
        } else {
          openMobileNav();
        }
      });

      if (mobileCloseBtn) {
        mobileCloseBtn.addEventListener('click', closeMobileNav);
      }

      // Focus trap + Escape
      mobileNav.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          closeMobileNav();
          return;
        }
        if (e.key !== 'Tab') return;
        var focusable = mobileNav.querySelectorAll('a[href], button, [tabindex]:not([tabindex="-1"])');
        if (!focusable.length) return;
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      });
    }

    // ── Submenu click-to-toggle (desktop nav) ──
    var parentItems = document.querySelectorAll('.site-nav li');
    parentItems.forEach(function (li) {
      var sub = li.querySelector(':scope > ul');
      if (!sub) return;

      var btn = document.createElement('button');
      btn.className = 'submenu-toggle';
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Toggle submenu');
      var parentLink = li.querySelector(':scope > a');
      parentLink.after(btn);

      function toggleSubmenu(e) {
        e.preventDefault();
        e.stopPropagation();
        var wasOpen = li.classList.contains('submenu-open');

        document.querySelectorAll('.site-nav .submenu-open').forEach(function (el) {
          el.classList.remove('submenu-open');
          el.querySelector(':scope > .submenu-toggle').setAttribute('aria-expanded', 'false');
        });

        if (!wasOpen) {
          li.classList.add('submenu-open');
          btn.setAttribute('aria-expanded', 'true');
        }
      }

      btn.addEventListener('click', toggleSubmenu);
      parentLink.addEventListener('click', toggleSubmenu);
    });

    // ── Close submenus on outside click ──
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.site-nav')) {
        document.querySelectorAll('.site-nav .submenu-open').forEach(function (el) {
          el.classList.remove('submenu-open');
          el.querySelector(':scope > .submenu-toggle').setAttribute('aria-expanded', 'false');
        });
      }
    });

    // ── Close submenus on Escape ──
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.site-nav .submenu-open').forEach(function (el) {
          el.classList.remove('submenu-open');
          var toggle = el.querySelector(':scope > .submenu-toggle');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.focus();
        });
        if (mobileNav && mobileNav.classList.contains('is-open')) {
          closeMobileNav();
        }
      }
    });

    // ── Share button ──
    var shareBtn = document.getElementById('global-share');
    if (shareBtn) {
      shareBtn.addEventListener('click', function (e) {
        e.preventDefault();
        var url = window.location.href;
        if (navigator.share) {
          navigator.share({ title: document.title, url: url });
        } else if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url);
          shareBtn.textContent = '[copied!]';
          setTimeout(function () { shareBtn.textContent = '[share]'; }, 1500);
        }
      });
    }

    // ── Mobile share button ──
    var mobileShareBtn = document.getElementById('mobile-share');
    if (mobileShareBtn) {
      mobileShareBtn.addEventListener('click', function (e) {
        e.preventDefault();
        var url = window.location.href;
        if (navigator.share) {
          navigator.share({ title: document.title, url: url });
        } else if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url);
          mobileShareBtn.textContent = '[copied!]';
          setTimeout(function () { mobileShareBtn.textContent = '[share]'; }, 1500);
        }
      });
    }

    // ── Theme toggle (light/dark) ──
    var themeToggle = document.getElementById('theme-toggle');
    var mobileThemeToggle = document.getElementById('mobile-theme-toggle');

    function updateThemeLabels(theme) {
      var label = theme === 'dark' ? '[light]' : '[dark]';
      if (themeToggle) themeToggle.textContent = label;
      if (mobileThemeToggle) mobileThemeToggle.textContent = label;
    }

    if (themeToggle) {
      var currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
      updateThemeLabels(currentTheme);

      themeToggle.addEventListener('click', function (e) {
        e.preventDefault();
        var current = document.documentElement.getAttribute('data-theme') || 'dark';
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('sarkin-theme', next);
        document.cookie = 'sarkin-theme=' + next + ';domain=.jonsarkin.com;path=/;max-age=31536000;SameSite=Lax';
        updateThemeLabels(next);
      });
    }

    if (mobileThemeToggle) {
      var mobileCurrentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
      updateThemeLabels(mobileCurrentTheme);

      mobileThemeToggle.addEventListener('click', function (e) {
        e.preventDefault();
        var current = document.documentElement.getAttribute('data-theme') || 'dark';
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('sarkin-theme', next);
        document.cookie = 'sarkin-theme=' + next + ';domain=.jonsarkin.com;path=/;max-age=31536000;SameSite=Lax';
        updateThemeLabels(next);
      });
    }
  })();
  </script>
</body>
</html>
