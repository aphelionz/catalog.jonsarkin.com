#!/usr/bin/env bash
set -euo pipefail

: "${QDRANT_URL:?QDRANT_URL is required}"
: "${COLLECTION:?COLLECTION is required}"
: "${BACKUP_ROOT:?BACKUP_ROOT is required}"
: "${GCS_BUCKET:?GCS_BUCKET is required (e.g. jonsarkin-backups-prod)}"
: "${GCS_PREFIX:=qdrant}"   # optional, default prefix inside bucket

backup_dir="${BACKUP_ROOT%/}/${COLLECTION}"
mkdir -p "$backup_dir"

curl_args=(-sSf)
if [[ -n "${QDRANT_API_KEY:-}" ]]; then
  curl_args+=( -H "api-key: ${QDRANT_API_KEY}" )
fi

create_response="$(curl "${curl_args[@]}" -X POST "${QDRANT_URL%/}/collections/${COLLECTION}/snapshots?wait=true")"
snapshot_name="$(echo "$create_response" | jq -r '.result.name // empty')"

if [[ -z "$snapshot_name" ]]; then
  echo "Failed to parse snapshot name from response:" >&2
  echo "$create_response" >&2
  exit 1
fi

snapshot_path="${backup_dir}/${snapshot_name}"
metadata_path="${snapshot_path}.json"
checksum_path="${snapshot_path}.sha256"

echo "$create_response" > "$metadata_path"

curl "${curl_args[@]}" -o "$snapshot_path" "${QDRANT_URL%/}/collections/${COLLECTION}/snapshots/${snapshot_name}"

sha256sum "$snapshot_path" > "$checksum_path"

curl "${curl_args[@]}" -X DELETE "${QDRANT_URL%/}/collections/${COLLECTION}/snapshots/${snapshot_name}"

# Upload artifacts to GCS
gcs_base="gs://${GCS_BUCKET%/}/${GCS_PREFIX%/}/${COLLECTION}/"
gcloud storage cp "$snapshot_path"   "${gcs_base}${snapshot_name}"
gcloud storage cp "$metadata_path"   "${gcs_base}${snapshot_name}.json"
gcloud storage cp "$checksum_path"   "${gcs_base}${snapshot_name}.sha256"
{% if qdrant_gcs_delete_local | default(false) %}

# Delete local artifacts after successful upload.
rm -f "$snapshot_path" "$metadata_path" "$checksum_path"
{% endif %}
